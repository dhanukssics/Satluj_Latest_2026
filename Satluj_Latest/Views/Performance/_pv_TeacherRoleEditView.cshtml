}
<style>
    .popup-btn {
        margin-top: 10px;
        margin: auto;
        display: block;
    }

    .toggleable-div {
        margin-bottom: 10px;
    }

    .toggle-heading {
        background: #03a9f4;
        color: #fff;
        padding: 5px 15px;
        border: 1px solid #f9f9f9;
    }

        .toggle-heading i {
            cursor: pointer;
            font-size: 20px;
        }

    .toggle-body {
        background: #ccc;
        padding: 15px;
        display: none;
        float: left;
        width: 100%;
    }

        .toggle-body ul {
            padding: 0;
        }

            .toggle-body ul li {
                display: block;
                float: left;
                margin-right: 30px;
                width: 22%;
                margin-bottom: 10px;
            }

    .sub-menu ul li > a > i {
        font-size: 9px !important;
    }

    .toggle-body ul li input[type=checkbox] {
        margin-right: 5px;
        margin-top: 7px;
        float: left;
    }

    .toggle-body ul li span {
        float: left;
        white-space: nowrap;
        text-overflow: ellipsis;
        width: calc(100% - 25px);
        overflow: hidden;
    }

    .toggle-class-width {
        margin-left: 2px;
        margin-right: 2px;
    }
</style>
