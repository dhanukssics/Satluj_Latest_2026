@model Satluj_Latest.Models.SmsPackageModels

<div class="modal-dialog modal-sm" role="document">

    <style>
        span {
            color: red;
        }
    </style>

    <form id="form-login"
          asp-action="AddSmsPackage"
          asp-controller="SuperAdmin"
          method="post">

        <input type="hidden" asp-for="SchoolId" />

        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">Add Package</h4>
            </div>

            <div class="modal-body">

                <div class="form-group">
                    <label asp-for="FromDate"></label>
                    <div class="calendar-inp pos_icon_adj">
                        <i class="fa fa-calendar" style="margin-left: 90%;"></i>
                        <input asp-for="FromDate" class="form-control" />
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="ToDate"></label>
                    <div class="calendar-inp pos_icon_adj">
                        <i class="fa fa-calendar" style="margin-left: 90%;"></i>
                        <input asp-for="ToDate" class="form-control" />
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="AllowedSms"></label>
                    <input asp-for="AllowedSms" class="form-control" autocomplete="off" />
                    <span asp-validation-for="AllowedSms"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SmsRate"></label>
                    <input asp-for="SmsRate" class="form-control" autocomplete="off" />
                    <span asp-validation-for="SmsRate"></span>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="submit" class="btn pay-now-btn">Save</button>
            </div>
        </div>
    </form>
</div>
<script>
    $("#form-login").submit(function (e) {
        e.preventDefault();

        $.ajax({
            url: $(this).attr("action"),
            type: "POST",
            data: $(this).serialize(),
            success: function (response) {
                AddSmsPackageSuccess(response);
            },
            error: function () {
                ajaxFailure();
            }
        });
    });
</script>
