<body>

    @{
        var action = ViewContext.RouteData.Values["action"]?.ToString().ToLower();
        var controller = ViewContext.RouteData.Values["controller"]?.ToString().ToLower();

        int userType = Context.Session.GetInt32("UserType") ?? 0;

        int teacherType = (int)UserRole.Teacher;
        int schoolType = (int)UserRole.School;
        int staffType = (int)UserRole.Staff;

        var userJson = Context.Session.GetString("User");
        TbLogin user = null;

        if (!string.IsNullOrEmpty(userJson))
        {
            user = Newtonsoft.Json.JsonConvert.DeserializeObject<TbLogin>(userJson);
        }

        var userData = new Satluj_Latest.Data.Login(user);
    }


    <section>
