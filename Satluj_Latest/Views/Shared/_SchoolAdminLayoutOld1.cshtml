                    </div>
                    <div class="lg_out">
                        <ul>
                            <li>@userData.Name</li>
                            <li>|</li>
                            @if (userType == teacherType || userType == staffType)
                            {
                                <li><a href="/Logout/StaffLogout"><i class="fa  fa-power-off"></i></a></li>
                            }
                            else if (userType == schoolType)
                            {
                                <li><a href="/Logout/SchoolLogout"><i class="fa  fa-power-off"></i></a></li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

