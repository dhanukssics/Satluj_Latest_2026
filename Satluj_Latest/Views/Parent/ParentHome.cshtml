    $(document).on('click', '#proceed-otp', function () {
        var studentId = $(this).attr('data-studentId');
        var otp = $("#OTP-value").val();

        if (otp != "") {
            $.ajax({
                url: '/Parent/OtpSubmit/' + studentId + '~' + otp,
                type: "GET",
                dataType: 'json',
                success: function (data) {
                    if (data.status) {

                        toastrSuccess(data.msg);
                        $('#addChild').modal('hide');
                        $('#enterSmsOtpModel').modal('hide');

                        window.location.reload();
                    }
                    else {
                        toastrError(data.msg);
                    }

                }
            });
        }
        else {
            toastrWarning("Please enter OTP");
        }
    });

