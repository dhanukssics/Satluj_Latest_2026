@model Satluj_Latest.Models.ParentRegisterModel
@{
    ViewBag.Title = "ParentHome";
    Layout = "~/Views/Shared/_ParentLayout.cshtml";
    var children = new Satluj_Latest.Data.Parent(Model.parentId).GetChildren();
    List<string> list = new List<string> { "VI", "VII", "VIII", "IX", "XI", "XII", "XI-CS1", "XI-BS", "XI-CC", "XII-CS", "XII-BS", "XII-CC", "XI SCIENCE", "XI COMMERCE", "XI HUMANITIES", "XII SCIENCE", "XII COMMERCE", "XII HUMANITIES" };
}

<style>
    .student-msg-span.msg-active {
        /*background: #61bfbf;*/
        background:#264C73;
    }

        .student-msg-span.msg-active:after {
            content: "";
            width: 0;
            height: 0;
            border-bottom: 26px solid transparent;
            border-top: 25px solid transparent;
            /*border-left: 15px solid #61bfbf;*/
            /*border-left: 15px solid #0394d1;*/
            border-left: 15px solid #264C73;
            font-size: 0;
            line-height: 0;
            position: absolute;
            right: -15px;
            top: 0px;
        }

    .student-msg-span {
        /*background: #0394d1;*/
        background: #264C73;
        display: block;
        padding: 10px 15px;
        margin-bottom: 20px;
        position: relative;
    }

        .student-msg-span:last-child {
            margin-bottom: 0px;
        }

        .student-msg-span p {
            margin-bottom: 0px !important;
        }

    .noMsg {
        text-align: center !important;
        font-weight: bold;
        font-size: 30px;
        color: white;
    }

    .msgMain {
        padding: 30px;
        /*background: #ffffff26;*/
        background: #73b3ce;
        color: #000;
        max-height: 450px;
        overflow-y: auto;
        margin-bottom: 4px;
        padding:1%;
        float:left;
    }

    #btn-load-more {
        text-align: center;
        padding: 10px 15px;
        margin: auto;
        display: table;
        margin-bottom: 20px;
        background: #ccc;
    }

    .chatMain {
        width: 100%;
        float: left;
        position: relative;
    }

    .chatSngl {
        padding: 10px 15px;
        box-shadow: 0px 4px 10px rgba(0,0,0,0.3);
        color: #000;
        margin-bottom: 12px;
        border-radius: 6px;
        min-width: 32%;
        max-width: 70%;
    }

        .chatSngl span {
            /*width:100%;*/
            display: block;
        }

    .tchrNme {
        font-weight: bold;
        font-size: 17px;
    }

    .timeCht {
        font-size: 12px;
        color: #545454;
        margin-top: 5px;
        padding-top: 6px;
        border-top: 1px solid #c3c3c3;
    }

    .chatMain > .pull-left:after {
        content: "";
        width: 0;
        height: 0;
        border-bottom: 15px solid transparent; /* left arrow slant */
        border-top: 15px solid transparent; /* right arrow slant */
        border-right: 15px solid #e6e6e6; /* bottom, add background color here */
        font-size: 0;
        line-height: 0;
        position: absolute;
        left: -15px;
        top: 15px;
    }

    .chatMain > .pull-right:after {
        content: "";
        width: 0;
        height: 0;
        border-bottom: 15px solid transparent; /* left arrow slant */
        border-top: 15px solid transparent; /* right arrow slant */
        border-left: 15px solid #fff6b8; /* bottom, add background color here */
        font-size: 0;
        line-height: 0;
        position: absolute;
        right: -15px;
        top: 15px;
    }

    .chatRight .chatSngl {
        background: #fff6b8;
    }

    .chatLeft .chatSngl {
        background: #e6e6e6;
    }

    .msg-sty-dev {
        display: block;
        float: left;
        width: 100%;
    }
    .parentLogin .login.contSpc{
        padding: 45px 0px 30px;
    }
    .loginHeight{min-height: 525px;}

    @@media screen and (max-width:768px){
        .parentLogin .login { padding: 60px 0 25px; }
        div#student-msg-name-maindiv { padding: 0; }
        .msgMain {
            margin-bottom: 20px;
        }
        .loginHeight {
            min-height: 400px;
        }
    }

</style>

<section class="login-body parentLogin loginHeight">
    <div class="parentbottom">
        <div class="container">
             <!--<div class="row">-->

                <div class="col-md-12">
                    <div class="login contSpc">
                        <div class="parent-home fullWid">
                            <div class="row" style="width:100%;">

                                @foreach (var child in children)
                                {
                                    <div style="float: left; width: 100%;">
                                        <div class="col-md-3" id="student-msg-name-maindiv">
                                            <span style="cursor: pointer;" class="student-msg-span msg-active" data-id="@child.StudentId"><p class=""><i class="fa fa-graduation-cap" aria-hidden="true"></i> @child.StundentName</p></span>
                                        </div>

                                        <div id="message-view-div" class="msgMain">
                                            <ul class="listhome">
                                                <li><a class="prtvbtn" data-childId="@child.StudentId" data-admission="@child.StudentSpecialId" href="/Parent/Attendance/@child.StudentId"><span><i class="fa fa-user-times" aria-hidden="true"></i></span> Attendence</a></li>
                                                <li><a id="btn-progressCard" class="prtvbtn" data-childId="@child.StudentId" data-className="@child.ClassName" data-admission="@child.StudentSpecialId" href="/Parent/ProgressCard/@child.StudentId"><span><i class="fa fa-line-chart" aria-hidden="true"></i></span>  Progress Card</a></li>
                                                @*<li><a id="btn-progressCard" class="prtvbtn" data-childId="@child.StudentId" data-className="@child.ClassName" data-admission="@child.StudentSpecialId" href="/Parent/Uploaded_Assignments/@child.ClassId"><span><i class="fa fa-line-chart" aria-hidden="true"></i></span> Assignments</a></li>*@
                                            
                                            <li><a id="btn-progressCard" class="prtvbtn" data-childId="@child.StudentId" data-className="@child.ClassName" data-admission="@child.StudentSpecialId" href="/Parent/Uploaded_Assignments/@child.StudentId"><span><i class="fa fa-line-chart" aria-hidden="true"></i></span> Assignments</a></li>
                                            
                                            </ul>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="fullWid" style="margin:15px 0 25px;" >
                        <a id="btn-addChild" class="addStdnts" style="margin-right:20px;"><img src="~/Content/img/add.png"> ADD YOUR CHILD</a>
                        @*<a id="btn-payChild" class="addStdnts" href="/Parent/ChildAcademyPayment" style="margin-right:20px;"> CHILD ACADEMY</a>*@
                        @*<a id="btn-payChild" class="addStdnts" href="/Parent/CoursesOffered"> COURSES OFFERED</a>*@
                    </div>


                </div><!-- /col-md-4 -->
           <!-- </div>  -->
        </div><!-- /container -->
    </div>
</section>

