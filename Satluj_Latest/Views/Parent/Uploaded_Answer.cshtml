@model Satluj_Latest.Models.ExamResultMainModel


@{

    Layout = "~/Views/Shared/_ParentLayout.cshtml";
}

<style>

    .with-icon {
        position: relative;
    }

        .with-icon i {
            position: absolute;
            right: 12px;
            top: 12px;
        }

    input[type=text], input[type=password], textarea, select {
        border: 1px solid #ccc;
    }

    .schooJs {
        padding: 50px 0px;
        min-height: 85vh;
    }

    .student-name-design {
        color: #0394d1;
        filter: contrast;
        margin-bottom: 4%;
        font-weight: bold;
    }

    #saveSubject {
        display: inline-block;
        border-radius: 5px;
        border: 4px double #cccccc;
        color: #eeeeee;
        text-align: center;
        font-size: 10px;
        padding: 10px;
        width: 100px;
        background-color: cornflowerblue;
        cursor: pointer;
        margin: 5px;
    }

    #temp {
        background-color: lawngreen;
        max-width: 500px;
        margin: auto;
        border: 3px solid #73AD21;
    }
</style>

@using (Html.BeginForm("Answer_Uploaded", "Parent", FormMethod.Post, new { enctype = "multipart/form-data" }))
{


    @Html.HiddenFor(z => z.ClassId, new { Value = @Model.ClassId })
    @Html.HiddenFor(z => z.StudentId, new { Value = @Model.StudentId })

    <section class="schooJs">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">

                    <div class="form-group col-sm-3" style="margin-top: 100px;">




                        <div class="form-group">
                            <label>Subjects : </label>
                            <br />


                            <select asp-for="SubjectId"
                                    asp-items="ViewBag.SubjectList"
                                    class="form-control"
                                    data-live-search="true"
                                    name="classDropdown"
                                    id="subjectId">
                            </select>

                            <span asp-validation-for="SubjectId" class="text-danger"></span>


                        </div>



                        <div class="form-group">
                            <br />

                            @Html.TextArea("description", "", new { @class = "form-control date-add", placeholder = "Description", id = "description", required = "required" })
                            @Html.ValidationMessageFor(m => m.Description)

                        </div>



                        <div class="form-group">

                            <div class="with-icon">
                                @Html.TextBox("TrackFile", "", new { @type = "file", @multiple = "multiple", id = "fileinput" }) <br />

                            </div>
                        </div>

                    </div>

                </div>



                <div class="form-group">

                    <button background-color:green; id="saveSubject"><i class="fa fa-save"></i> Save </button>


                </div>
            </div>

            @if (TempData["alertMessage"] != null)
            {
                <div class="btn fa-pull-right" id="temp">
                    <hi>      @TempData["alertMessage"]</hi>
                </div>
            }

        </div>










    </section>

}




