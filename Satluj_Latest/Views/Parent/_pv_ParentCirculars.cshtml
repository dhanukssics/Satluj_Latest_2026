@model Satluj_Latest.Models.ParentStudentClassModel
@{
    var Circulars = new Satluj_Latest.Data.Parent(Model.ParentId).ParentCircularList();
}

<style>
    .time_date {
        margin: 0 10px;
    }

    .cust_listing ul li a {
        margin: 0 15px;
    }

        .cust_listing ul li a:hover {
            text-decoration: none;
            color: #000;
        }

    .head-dsign {
        font-weight: bold;
        font-size: 16px;
    }
</style>

<div class="col-12" style="margin-top: 3%;">
    <div class="cust_listing">
        <ul>
            @foreach (var item in Circulars)
            {
                var url = "http://satluj.edumanonline.com" + item.FilePath;
                if (item.FilePath == null)
                {
                    <li style="border-bottom: 1px solid black;">
                        <span class="time_date head-dsign">@item.CircularDate.ToShortDateString()</span>  <a href="#" class="head-dsign">No Files</a>
                        <div class="Details_sec">
                            <p>@item.Description</p>
                        </div>
                    </li>
                }
                else
                {
                <li style="border-bottom: 1px solid black;">
                    <span class="time_date head-dsign">@item.CircularDate.ToShortDateString()</span>  <a href="@url"  target="_blank" class="head-dsign">File</a>
                    <div class="Details_sec">
                        <p>@item.Description</p>
                    </div>
                </li>
                }
            }
        </ul>
    </div>
</div>
