        $(".skill_selction").html("");
        var id = $(".slct-subject-dropdown option:selected").val();
        if (id != '') {
            $.ajax({
                url: '/Data/Scholasticareas_others?id=' + id + '~' + $('#SchoolId').val(),
                type: "GET",
                success: function (result) {
                    if (result.list.length > 0) {
