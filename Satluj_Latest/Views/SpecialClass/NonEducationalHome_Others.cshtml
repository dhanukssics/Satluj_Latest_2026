                $.ajax({
                    url: '/Data/LoadSpecialDivission_others?id=' + id + '~' + $('#SchoolId').val(),
                    type: "GET",
                    success: function (result) {
                        if (result.list.length > 0) {
                            $(".class-drop-down").html("");
