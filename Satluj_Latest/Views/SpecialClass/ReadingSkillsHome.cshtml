    function LoadDetails() {
        var admin = $('#IsAdminCheck').val();
        if (admin == 0) {
            LoadAsNonAdmin();
        }
        else {
            LoadAsAdmin();
        }
      
    };

    //For admin 
    function LoadAsAdmin() {
        var divisionId = $(".division-drop-down option:selected").val();
        var subjectId = $(".slct-subject-dropdown option:selected").val();
        var skillId = $(".skill_selction option:selected").val();
        var assesmentId = $(".assesment-id option:selected").val();
        var id = divisionId + '~' + subjectId + '~' + skillId + '~' + assesmentId;
        $.ajax({
            url: '/SpecialClass/LoadAllStudentsWithSkillsMarks?id=' + id,
            type: "GET",
            dataType: 'html',
            success: function (data) {
                $('#result-entry-div-id').html('');
                $('#result-entry-div-id').html(data);
            }
        });
    }

    //For non admin
    function LoadAsNonAdmin() {
        var divisionId = $(".division-drop-down option:selected").val();
        var subjectId = $(".slct-subject-dropdown option:selected").val();
        var skillId =  $(".skill_selctionByTeacher option:selected").val();
        var assesmentId = $(".assesment-id option:selected").val();
        var id = divisionId + '~' + subjectId + '~' + skillId + '~' + assesmentId;
        $.ajax({
            url: '/SpecialClass/LoadAllStudentsWithSkillsMarks?id=' + id,
            type: "GET",
            dataType: 'html',
            success: function (data) {
                $('#result-entry-div-id').html('');
                $('#result-entry-div-id').html(data);
            }
        });
    }

    $("#students-Mark-Search_btn").click(function () {
        var assesmentId = $(".assesment-id option:selected").val();
        if (assesmentId == 0) {
            toastrError('Please select the Assesment!');
        }
        else {
            var divisionId = $(".division-drop-down option:selected").val();
            if (divisionId == 0) {
                toastrError('Please select the division!');
            }
            else {
                var subjectId = $(".slct-subject-dropdown option:selected").val();
                if (subjectId == 0) {
                    toastrError('Please select the subject!');
                }
                else {
                    LoadDetails();
                }
            }
        }
    });

    $(document).on('change', '.slct-subject-dropdown', function () {
        var id = $(this).val();
        $('#SubjectId').val(id);
    });

    //READING SKILL SAVE
    $(document).on('click', '#students-reading-skill-Save_btn', function () {
        var source = $(this);
        storeReadingSkills(source);
    });

    function storeReadingSkills(source) {
        debugger;
        var dataList = new Object();
        dataList.SchoolId = $('#SchoolId').val();
        dataList.DivisionId = $('#DivisionId').val();
        dataList.AssesmentId = $('#AssesmentId').val();
        dataList.SubjectId = $('#SubjectId').val();
        dataList._SkillModel = [];
        $('.cls-tr-class').each(function (index, elem) {
            var data = new Object();
            data._ReadingSkill = new Object();
            data.StudentId = $(this).attr('data-StudentId');
            //data._ReadingSkill.Pronun = $(this).find('.cls-mark-Pronun').val();
            //data._ReadingSkill.Fluency = $(this).find('.cls-mark-Fluency').val();
            data._ReadingSkill.Pronun = $(this).find('.cls-mark-Reading').val();
            data.StudentName = '';
            dataList._SkillModel.push(data);
        });
        $.ajax({
            url: "/SpecialClass/SubmitStudentReadingSkill",
            type: "POST",
            dataType: 'json',
            data: dataList,
            global: false,
            success: function (response) {
                if (response.status) {
                    toastrSuccess(response.msg);
                    LoadDetails();
                }
                else {
                    toastrError(response.msg);
                }
            },
            error: function (data) {
            }
        });
    };

