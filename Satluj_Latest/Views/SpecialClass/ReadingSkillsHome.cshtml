            data.StudentId = $(this).attr('data-StudentId');
            data.StudentName = '';
            data._AspectsRelativeAreas.ComputerScience = $(this).find('.cls-mark-ComputerScience').val();
            data._AspectsRelativeAreas.GeneralStudies = $(this).find('.cls-mark-GeneralStudies').val();
            data._AspectsRelativeAreas.Valueeducation = $(this).find('.cls-mark-Valueeducation').val();
            data._AspectsRelativeAreas.French = $(this).find('.cls-mark-French').val();
            data._AspectsRelativeAreas.SmartClass = $(this).find('.cls-mark-SmartClass').val();
            dataList._SkillModel.push(data);
        });
        $.ajax({
            url: "/SpecialClass/SubmitStudentAspectRelativeStudiesSkill",
            type: "POST",
            dataType: 'json',
            data: dataList,
            global: false,
            success: function (response) {
                if (response.status) {
                    toastrSuccess(response.msg);
                    LoadDetails();
                }
                else {
                    toastrError(response.msg);
                }
            },
            error: function (data) {
            }
        });
    };

    //LIST SUBJECT BY USER
    $(document).on('change', '.skill_selctionByTeacher', function () {
        $('#result-entry-div-id').html('');
        var divisionId = $(".division-drop-down option:selected").val();
        if (divisionId == 0) {
            //toastrError('Please select the division!');
        }
        else {      
            var id = $(this).val();
            if (id != '') {
                $.ajax({
                    url: '/Data/LoadSpecialSubjectsByTeacher?id=' + id + '~' + $('#SchoolId').val() + '~' + $('#UserId').val() + '~' + divisionId,
                    type: "GET",
                    success: function (result) {
                        if (result.list.length > 0) {
                            $(".slct-subject-dropdown").html("");
                            $(".slct-subject-dropdown").append($('<option></option>').val("0").html('-- Select Subject --'));
                            $.each(result.list, function (i, item) {
                                $(".slct-subject-dropdown").append($('<option></option>').val(item.Value).html(item.Text));
                            });
                            $(".slct-subject-dropdown").prop("disabled", false);
                        }
                        else {

                            $(".slct-subject-dropdown").html("");
                            $(".slct-subject-dropdown").append($('<option></option>').val("").html('---'));
                            $(".slct-subject-dropdown").prop("disabled", true);
                        }
                    }
                });
            }
            else {
                $(".slct-subject-dropdown").html("");
                $(".slct-subject-dropdown").append($('<option></option>').val("").html('---'));
                $(".slct-subject-dropdown").prop("disabled", true);
            }
        }
    });

