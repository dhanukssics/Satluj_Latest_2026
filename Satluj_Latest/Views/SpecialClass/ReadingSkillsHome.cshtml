@model Satluj_Latest.Models.SubjectScoreModel
@{
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
        bool IsAdmin = ViewBag.IsAdmin;
}
@Html.HiddenFor(z => z.SchoolId, new { Value = @Model.SchoolId })
@Html.HiddenFor(z => z.SubjectId, new { Value = @Model.SubjectId })
@Html.HiddenFor(z => z.UserId, new { Value = @Model.UserId })
@Html.HiddenFor(z => z.IsAdminCheck, new { Value = @Model.IsAdminCheck })

<div class="row">
    <div class="col-lg-12">
        <h3 style="margin-top: 5px;"> V Class Result</h3>
        @if (IsAdmin)
        {
            <div class="row">
                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Assesments : </label>
                        <br />
                        <select asp-for="AssesmentTableId"
                                asp-items="ViewBag.Vassessments"
                                class="form-control assesment-id"
                                data-live-search="true"
                                name="classDropdown">
                            <option value="">--Choose--</option>
                        </select>

                        <span asp-validation-for="AssesmentTableId" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Division : </label>
                        <br />
                        <select asp-for="DivisionId"
                                asp-items="ViewBag.VClassDivisinLists"
                                class="form-control division-drop-down class-drop-down"
                                data-live-search="true"
                                name="classDropdown">
                            <option value="">--Choose--</option>
                        </select>

                        <span asp-validation-for="DivisionId" class="text-danger"></span>

                    </div>
                </div>
                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Skill : </label>
                        <br />
                        <select asp-for="VSpecialMarksId"
                                asp-items="Html.GetEnumSelectList<VSpecialMarks>()"
                                class="form-control skill_selction"
                                data-live-search="true"
                                name="classDropdown">
                        </select>

                        <span asp-validation-for="VSpecialMarksId" class="text-danger"></span>

                    </div>
                </div>
                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Subject :</label>
                        <select class="form-control slct-subject-dropdown" disabled></select>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="row">
                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Assesments : </label>
                        <br />
  <select asp-for="AssesmentTableId"
                                asp-items="ViewBag.Vassessments"
                                class="form-control assesment-id"
                                data-live-search="true"
                                name="classDropdown">
                            <option value="">--Choose--</option>
                        </select>

                        <span asp-validation-for="AssesmentTableId" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Division : </label>
                        <br />
                        <select asp-for="DivisionId"
                                asp-items="ViewBag.Vdivisionlistuser"
                                class="form-control division-drop-down class-drop-down"
                                data-live-search="true"
                                name="classDropdown">
                            <option value="">--Choose--</option>
                        </select>

                        <span asp-validation-for="DivisionId" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Skill : </label>
                        <br />
                        <select asp-for="VSpecialMarksId"
                                asp-items="Html.GetEnumSelectList<VSpecialMarks>()"
                                class="form-control skill_selction"
                                data-live-search="true"
                                name="classDropdown">
                        </select>

                        <span asp-validation-for="VSpecialMarksId" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Subject :</label>
                        <select class="form-control slct-subject-dropdown" disabled></select>
                    </div>
                </div>
            </div>
        }

    </div>
</div>
<div class="row col-lg-3">
    <button type="button" id="students-Mark-Search_btn" style="width: 100%;" class="btn pay-now-btn">Search</button>
</div>
<div class="row col-lg-12" id="result-entry-div-id" style="margin-top:10px;">

</div>

<script>

    $(document).on('change', '.skill_selction', function () {
        $('#result-entry-div-id').html('');
        var id = $(this).val();
        if (id != '') {
            $.ajax({
                url: '/Data/LoadSpecialSubjects?id=' + id + '~' + $('#SchoolId').val(),
                type: "GET",
                success: function (result) {
                    if (result.list.length > 0) {
                        $(".slct-subject-dropdown").html("");
                        $(".slct-subject-dropdown").append($('<option></option>').val("0").html('-- Select Subject --'));
                        $.each(result.list, function (i, item) {
                            $(".slct-subject-dropdown").append($('<option></option>').val(item.Value).html(item.Text));
                        });
                        $(".slct-subject-dropdown").prop("disabled", false);
                    }
                    else {

                        $(".slct-subject-dropdown").html("");
                        $(".slct-subject-dropdown").append($('<option></option>').val("").html('---'));
                        $(".slct-subject-dropdown").prop("disabled", true);
                    }
                }
            });
        }
        else {
            $(".slct-subject-dropdown").html("");
            $(".slct-subject-dropdown").append($('<option></option>').val("").html('---'));
            $(".slct-subject-dropdown").prop("disabled", true);
        }
    });

