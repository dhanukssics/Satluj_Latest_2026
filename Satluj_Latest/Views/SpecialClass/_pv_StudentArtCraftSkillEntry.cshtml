


@model Satluj_Latest.Models.StudentSkillMarks
@{
    int count = 1;
        bool IsAdmin = ViewBag.IsAdmin;
}
@Html.HiddenFor(z => z.SchoolId, new { Value = @Model.SchoolId })
@Html.HiddenFor(z => z.DivisionId, new { Value = @Model.DivisionId })
@Html.HiddenFor(z => z.AssesmentId, new { Value = @Model.AssesmentId })
@Html.HiddenFor(z => z.SubjectId, new { Value = @Model.SubjectId })
<div class="table-responsive">
    <table class="table account-table" id="tbstdMarkList">
        <tr id="thead">
            <th style="color: black;">
                Sl.No
            </th>
            <th style="color: black;">
                Student Name
            </th>
            <th style="color: black;">
                ART
            </th>
            @*<th style="color: black;">
                CREATIVITY
            </th>*@
        </tr>
        <tbody id="bodyTable">

            @foreach (var item in Model._SkillModel)
            {
                <tr data-id="tbRowAmount" style="color:black;" data-StudentId="@item.StudentId" class="cls-tr-class">
                    <td style="width:10%;">
                        @count
                    </td>
                    <td style="width:50%;">
                        @item.StudentName
                    </td>
                    <td style="width:40%;">
                        @if (item._ArtCraft.Interest.Trim() == "")
                        {
                            <div>
                                <input value="@item._ArtCraft.Interest"  maxlength="2" style="color:black; " class="cls-mark-Interest" id="@count" />
                            </div>
                        }
                        else
                        {
                            <div>
                                @if (IsAdmin == true)
                                {
                                    <input value="@item._ArtCraft.Interest"  maxlength="2"  style="color:black; " class="cls-mark-Interest" id="@count" />
                                }
                                else
                                {
                                    <input value="@item._ArtCraft.Interest"   maxlength="2" style="color:black; " class="cls-mark-Interest" readonly id="@count" />
                                }
                            </div>
                        }
                    </td>
                    @*<td style="width:40%;">
                        @if (item._ArtCraft.Creativity.Trim() == "")
                        {
                            <div>
                                <input value="@item._ArtCraft.Creativity"  maxlength="2"  style="color:black; " class="cls-mark-Creativity" id="@count" />
                            </div>
                        }
                        else
                        {
                            <div>
                                @if (IsAdmin == true)
                                {
                                    <input value="@item._ArtCraft.Creativity"  maxlength="2"  style="color:black; " class="cls-mark-Creativity" id="@count" />
                                }
                                else
                                {
                                    <input value="@item._ArtCraft.Creativity" maxlength="2"  style="color:black; " class="cls-mark-Creativity" readonly id="@count" />
                                }
                            </div>
                        }
                    </td>*@

                </tr>
                count = count + 1;
            }

        </tbody>
    </table>
    <div class="modal-footer">
        <button type="button" id="students-ArtCraft-Save_btn" style="width: 100%;" class="btn pay-now-btn">Save</button>
    </div>

</div>