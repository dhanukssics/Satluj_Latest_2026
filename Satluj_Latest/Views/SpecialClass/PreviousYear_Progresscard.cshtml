    $(document).on('change', '.Academicid', function () {
        var id = $(".Academicid option:selected").val();
        if (id != '') {
            $.ajax({
                url: '/Data/LoadSpecialClass_Previous?id=' + id + '~' + $('#SchoolId').val(),
                type: "GET",
                success: function (result) {
                    if (result.list.length > 0) {
                        $(".classDropdown").html("");
                        $(".classDropdown").append($('<option></option>').val("0").html('-- Select Class --'));
                        $.each(result.list, function (i, item) {
                            $(".classDropdown").append($('<option></option>').val(item.Value).html(item.Text));
                        });
                        $(".classDropdown").prop("disabled", false);
                    }
                    else {

                        $(".classDropdown").html("");
                        $(".classDropdown").append($('<option></option>').val("").html('---'));
                        $(".classDropdown").prop("disabled", true);
                    }
                }
            });
        }
        else {
            $(".classDropdown").html("");
            $(".classDropdown").append($('<option></option>').val("").html('---'));
            $(".classDropdown").prop("disabled", true);
        }



    });



</script>


