


@model Satluj_Latest.Models.StudentSkillMarks
@{
    int count = 1;
        bool IsAdmin = ViewBag.IsAdmin;
    var scoreDetails = new Satluj_Latest.Data.School(Model.SchoolId).Get_V_TotalScores(13);
    var Comprehension = "";
    var Listening_total = "";
    if (scoreDetails != null && scoreDetails.Count > 0)
    {
        //if (scoreDetails.Any(x => x.SubTitle == "Comprehension"))
        //{
        //    Comprehension = scoreDetails.Where(x => x.SubTitle == "Comprehension").FirstOrDefault().Mark.ToString();
        //}
        if (scoreDetails.Any(x => x.SubTitle == "ListeningSkill"))
        {
            Listening_total = scoreDetails.Where(x => x.SubTitle == "ListeningSkill").FirstOrDefault().Mark.ToString();
        }
    }
}
@Html.HiddenFor(z => z.SchoolId, new { Value = @Model.SchoolId })
@Html.HiddenFor(z => z.DivisionId, new { Value = @Model.DivisionId })
@Html.HiddenFor(z => z.AssesmentId, new { Value = @Model.AssesmentId })
@Html.HiddenFor(z => z.SubjectId, new { Value = @Model.SubjectId })
<div class="table-responsive">
    <table class="table account-table" id="tbstdMarkList">
        <tr id="thead">
            <th style="color: black;">
                Sl.No
            </th>
            <th style="color: black;">
                Student Name
            </th>
            @*<th style="color: black;">
            COMPREHENSION ( @Comprehension )
        </th>*@
            *
        <th style="color: black;">
            LISTENING (@Listening_total )
        </th>
        </tr>
        <tbody id="bodyTable">

            @foreach (var item in Model._SkillModel)
            {
                <tr data-id="tbRowAmount" style="color:black;" data-StudentId="@item.StudentId" class="cls-tr-class">
                    <td style="width:10%;">
                        @count
                    </td>
                    <td style="width:50%;">
                        @item.StudentName
                    </td>
                    <td style="width:40%;">
                        @if (item._ListenningSkill.Comprehension == "" || item._ListenningSkill.Comprehension == null)
                        {
                            <div>
                                <input value="@item._ListenningSkill.Comprehension" type="number" maxlength="3" style="color:black; " class="cls-mark-listening" id="@count" />
                            </div>
                        }
                        else
                        {
                            <div>
                                @if (IsAdmin == true)
                                {
                                    <input value="@item._ListenningSkill.Comprehension" type="number" maxlength="3" style="color:black; " class="cls-mark-listening" id="@count" />
                                }
                                else
                                {
                                    <input value="@item._ListenningSkill.Comprehension" type="number" maxlength="3" style="color:black; " class="cls-mark-listening" readonly id="@count" />
                                }
                            </div>
                        }

                    </td>
                </tr>
                count = count + 1;
            }

        </tbody>
    </table>
    <div class="modal-footer">
        <button type="button" id="students-Listening-skill_btn" style="width: 100%;" class="btn pay-now-btn">Save</button>
    </div>

</div>