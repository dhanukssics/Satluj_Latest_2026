@model Satluj_Latest.Models.AssetsLiabilityModel

<form id="form-login"
      asp-action="EditAssets"
      asp-controller="Journal"
      method="post">

    <input asp-for="Id" type="hidden" />

    <div class="col-md-6">

        <!-- Type -->
        <div class="form-group gap_bottom row">
            <div class="col-md-3">
                <label>Type</label>
            </div>
            <div class="col-md-9">
                <select asp-for="TypeId"
                        asp-items="Html.GetEnumSelectList<AssetsLiabilityType>()"
                        class="form-control pv_assests-type"
                        id="assets-type-id">
                    <option value="">--Choose--</option>
                </select>
                <span asp-validation-for="TypeId" class="text-danger"></span>
            </div>
        </div>

        <!-- Date -->
        <div class="form-group gap_bottom row">
            <div class="col-md-3">
                <label>Date</label>
            </div>
            <div class="col-md-9 calendar-inp pos_icon_adj">
                <input asp-for="EntryDateString"
                       class="form-control date-assests-add-date" />
            </div>
        </div>

        <!-- Invoice -->
        <div class="form-group gap_bottom row">
            <div class="col-md-3">
                <label>Invoice No</label>
            </div>
            <div class="col-md-9">
                <input asp-for="InviceNumber"
                       readonly
                       class="form-control"
                       placeholder="Invoice No" />
            </div>
        </div>

        <!-- Account Head -->
        <div class="form-group gap_bottom row">
            <div class="col-md-3">
                <label>Account Head</label>
            </div>
            <div class="col-md-9">
                <select asp-for="HeadId"
                        asp-items="ViewBag.Accounthead"
                        class="form-control"
                        id="assests-head-id">
                    <option value="">--Choose--</option>
                </select>
                <span asp-validation-for="HeadId" class="text-danger"></span>
            </div>
        </div>

        <!-- Amount -->
        <div class="form-group gap_bottom row">
            <div class="col-md-3">
                <label>Amount</label>
            </div>
            <div class="col-md-9">
                <input asp-for="Amount"
                       class="form-control"
                       id="amount-assets-id"
                       placeholder="Amount" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
        </div>

        <!-- Add Amount -->
        <div class="form-group gap_bottom row">
            <div class="col-md-3">
                <label>Add Amount</label>
            </div>
            <div class="col-md-1">
                <input asp-for="AddStatus"
                       class="form-check-input"
                       id="addstatus-id-check" />
            </div>
        </div>

        <!-- Narration -->
        <div class="form-group gap_bottom row">
            <div class="col-md-3">
                <label>Narration</label>
            </div>
            <div class="col-md-9">
                <input asp-for="Narration"
                       class="form-control"
                       placeholder="Narration" />
                <span asp-validation-for="Narration" class="text-danger"></span>
            </div>
        </div>

        <!-- Footer -->
        <div class="form-group gap_bottom">
            <div class="modal-footer">
                <button type="button" id="btn-cancel-assets" class="btn btn-secondary">
                    Cancel
                </button>
                <button type="submit" id="btn-edit-save-assets" class="btn pay-now-btn">
                    Edit
                </button>
                <button type="button" id="btn-print-assets-edit" class="btn pay-now-btn">
                    Print
                </button>
            </div>
        </div>

    </div>
</form>
$("#form-login").submit(function (e) {
    e.preventDefault();

    $.ajax({
        url: $(this).attr("action"),
        type: "POST",
        data: $(this).serialize(),
        success: function (response) {
            EditAssetsSuccess(response);
        },
        error: function () {
            EditAssetsFailed();
        }
    });
});
