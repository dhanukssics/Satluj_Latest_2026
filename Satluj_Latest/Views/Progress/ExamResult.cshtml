
@model Satluj_Latest.Models.ExamResultMainModel
@{
    ViewBag.Title = "ExamDeclaration";
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
        bool IsAdmin = ViewBag.IsAdmin;
}
@Html.HiddenFor(z => z.SchoolId, new { Value = @Model.SchoolId })
@Html.HiddenFor(z => z.ClassId, new { Value = 0 })
@Html.HiddenFor(z => z.DivisionId, new { Value = 0 })
@Html.HiddenFor(z => z.ExamId, new { Value = 0 })
@Html.HiddenFor(z => z.SubjectId, new { Value = 0 })
@Html.HiddenFor(z => z.UserId, new { Value = Model.UserId, id = "user-Id" })
<div class="row">
    <div class="col-md-12">
        <h3 style="margin-top: 5px;"> Exam Result</h3>
        @if (IsAdmin == true)
        {
            <div class="row">
                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Class : </label>
                        <br />
                        <select asp-for="ClassId"
                                asp-items="ViewBag.ClassList"
                                class="form-control pv_class-drop-down"
                                id="classDataDropdown">
                            <option value="">--Choose--</option>
                        </select>

                        <span asp-validation-for="ClassId" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group col-sm-3">
                    <label>Division</label>
                    <br />
                    <select id="division-drop-down" class="form-control slct-free-div-dropdown" disabled>
                        <option>--Select Division --</option>
                    </select>
                    <span id="spn-error-Division" data-val="0" data-myval="10" style="color:red;"></span>
                </div>

                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Exam :</label>
                        <select class="form-control slct-exam-dropdown1" disabled></select>
                        <span id="exam-required-examlist-add" style="display:none; color:red;"></span>
                    </div>
                </div>

                <div class="form-group col-sm-3">
                    <div class="form-group">
                        <label>Subject :</label>
                        <select class="form-control slct-subject-dropdown1" disabled></select>
                        <span id="exam-required-examlist-add" style="display:none; color:red;"></span>
                    </div>
                </div>
            </div>
            <div class="row isHidden total-score">
                <div class="form-group col-sm-3">
                    <button type="button" id="student-total-score-save" style="width: 100%;" class="btn pay-now-btn">Total Score</button>
                </div>
            </div>
        }
        else
        {
            var teacher = new Satluj_Latest.Data.Login(Model.UserId).RoleId;
            if (teacher == 3)
            {
                <div class="row">
                    <div class="form-group col-sm-3">
                        <div class="form-group">
                            <label>Class : </label>
                            <br />
                            <select asp-for="ClassId"
                                    asp-items="ViewBag.ClassListwise"
                                    class="form-control pv_class-drop-down class-drop-downNonAdmin"
                                    id="classDataDropdown">
                                <option value="">--Choose--</option>
                            </select>

                            <span asp-validation-for="ClassId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group col-sm-3">
                        <label>Division</label>
                        <br />
                        <select id="division-drop-downNonAdmin" class="form-control slct-free-div-dropdownNonAdmin" disabled>
                            <option>--Select Division --</option>
                        </select>
                        <span id="spn-error-Division" data-val="0" data-myval="10" style="color:red;"></span>
                    </div>

                    <div class="form-group col-sm-3">
                        <div class="form-group">
                            <label>Exam :</label>
                            <select class="form-control slct-exam-dropdown1NonAdmin" disabled></select>
                            <span id="exam-required-examlist-addNonAdmin" style="display:none; color:red;"></span>
                        </div>
                    </div>

                    <div class="form-group col-sm-3">
                        <div class="form-group">
                            <label>Subject :</label>
                            <select class="form-control slct-subject-dropdown1NonAdmin" disabled></select>
                            <span id="exam-required-examlist-addNonAdmin" style="display:none; color:red;"></span>
                        </div>
                    </div>
                </div>
                <div class="row isHidden total-score">
                    <div class="form-group col-sm-3">
                        <button type="button" id="student-total-score-save" style="width: 100%;" class="btn pay-now-btn">Total Score</button>
                    </div>
                </div>
            }
            else
            {
                <br />
                <br />
                <p>You don't have the Provision for view the Performance !</p>
            }
        }
        <div class="table-responsive">
            <table class="table custome-table" id="declaed-exam-student-mark-list"></table>
        </div>
    </div>
</div>

<div class="modal fade" id="model-view-space" tabindex="-1" role="dialog" aria-labelledby="myModalLabel"></div>
<script>

    //Division listing
    $(document).on('change', '.class-drop-down', function () {
        $('.total-score').addClass('isHidden');
        var id = $(this).val();
        $('#ClassId').val($(this).val());
        //$('#btn-pie-Generate').hide();
        if (id != '') {
            $.ajax({
                url: '/Data/LoadDivision?id=' + id,
                type: "GET",
                success: function (result) {
                    if (result.list.length > 0) {
                        $("#division-drop-down").html("");
                        $("#division-drop-down").append($('<option></option>').val("").html('-- Select Division --'));
                        $.each(result.list, function (i, item) {
                            $("#division-drop-down").append($('<option></option>').val(item.Value).html(item.Text));
                        });
                        $("#division-drop-down").prop("disabled", false);
                        $('#declaed-exam-student-mark-list').html('');
                        $(".slct-exam-dropdown1").html("");
                        $(".slct-exam-dropdown1").append($('<option></option>').val("").html('---'));
                        $(".slct-exam-dropdown1").prop("disabled", true);

                        $(".slct-subject-dropdown1").html("");
                        $(".slct-subject-dropdown1").append($('<option></option>').val("").html('---'));
                        $(".slct-subject-dropdown1").prop("disabled", true);

                        $('#declaed-exam-student-mark-list').html('');
                    }
                    else {
                        $("#division-drop-down").html("");
                        $("#division-drop-down").append($('<option></option>').val("").html('-- No Division Found --'));
                        $("#division-drop-down").prop("disabled", true);

                        $(".slct-exam-dropdown1").html("");
                        $(".slct-exam-dropdown1").append($('<option></option>').val("").html('---'));
                        $(".slct-exam-dropdown1").prop("disabled", true);

                        $(".slct-subject-dropdown1").html("");
                        $(".slct-subject-dropdown1").append($('<option></option>').val("").html('---'));
                        $(".slct-subject-dropdown1").prop("disabled", true);

                        $('#declaed-exam-student-mark-list').html('');
                    }
                }
            });
        }
        else {
            $("#division-drop-down").html("");
            $("#division-drop-down").append($('<option></option>').val("").html('-- No Division Found --'));
            $("#division-drop-down").prop("disabled", true);

            $(".slct-exam-dropdown1").html("");
            $(".slct-exam-dropdown1").append($('<option></option>').val("").html('---'));
            $(".slct-exam-dropdown1").prop("disabled", true);

            $(".slct-subject-dropdown1").html("");
            $(".slct-subject-dropdown1").append($('<option></option>').val("").html('---'));
            $(".slct-subject-dropdown1").prop("disabled", true);

            $('#declaed-exam-student-mark-list').html('');
        }
    });

