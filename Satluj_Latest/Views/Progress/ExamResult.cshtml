            $("#division-drop-downNonAdmin").append($('<option></option>').val("").html('-- No Division Found --'));
            $("#division-drop-downNonAdmin").prop("disabled", true);

            $(".slct-exam-dropdown1NonAdmin").html("");
            $(".slct-exam-dropdown1NonAdmin").append($('<option></option>').val("").html('---'));
