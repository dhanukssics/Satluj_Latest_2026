                        });
                        $(".slct-subject-dropdown1").prop("disabled", false);
                        $('#exam-required-examlist-add').hide();
                    }
                    else {

                        $(".slct-subject-dropdown1").html("");
                        $(".slct-subject-dropdown1").append($('<option></option>').val("").html('---'));
                        $(".slct-subject-dropdown1").prop("disabled", true);

                    }
                }
            });
        }
        else {
            $(".slct-subject-dropdown1").html("");
            $(".slct-subject-dropdown1").append($('<option></option>').val("").html('---'));
            $(".slct-subject-dropdown1").prop("disabled", true);
        }
    });

    //List Students
    $(document).on('change', '.slct-subject-dropdown1', function () {
        var higherSecondaryList =[ "XI", "XII", "XI-CS1", "XI-BS", "XI-CC", "XII-CS", "XII-BS", "XII-CC", "XI SCIENCE", "XI COMMERCE", "XI HUMANITIES", "XII SCIENCE", "XII COMMERCE", "XII HUMANITIES" ];
        var currentClass = $(".class-drop-down option:selected").text();
        if (currentClass != '') {
            var n = higherSecondaryList.includes(currentClass);
            if (n) {
                $('.total-score').removeClass('isHidden');
            }
            else {
                $('.total-score').addClass('isHidden');
            }
        }
        $('#declaed-exam-student-mark-list').html('');
        $('#SubjectId').val($(this).val());
        var classId = $('#ClassId').val();
        var divisionId = $('#DivisionId').val();
        var examId = $('#ExamId').val();
        var subjectId = $('#SubjectId').val();
        if (classId != '' && divisionId != '' && examId != '' && subjectId != '') {
            $.ajax({
                url: '/Progress/SudentListForEnterResult/' + subjectId + '~' + examId + '~' + classId + '~' + divisionId,
                type: "GET",
                dataType: 'html',
                success: function (data) {
                    $('#declaed-exam-student-mark-list').html(data);
                }
            });
        }
        else {

        }
    });

    //Save marks
    $(document).on('click', '#students-Mark-Save_btn', function () {
        var source = $(this);
        getFullData(source);
    });

    function getFullData(source) {
        var dataList = new Object();
        dataList.ClassId = $('#ClassId').val();
        dataList.DivisionId = $('#DivisionId').val();
        dataList.SubjectId = $('#SubjectId').val();
        dataList.IsEntered = $('#IsEntered').val();
        dataList.TotalScore = $('#TotalScore').val();
        dataList.SchoolId = $('#SchoolId').val();
        dataList.ExamId = $('#ExamId').val();
        dataList.ListData = [];
        $('.cls-tr-class').each(function (index, elem) {
            var data = new Object();
            data.StudentId = $(this).attr('data-StudentId');
            if ($(this).find('.cls-mark').val() != '')
                data.Mark = parseFloat($(this).find('.cls-mark').val()).toFixed(2);
            else
                data.Mark = '0.00';
            data.PracticalScore = $(this).find('.cls-mark-practical').val();
            data.StudentName = '';
            dataList.ListData.push(data);
        });
        console.log(dataList);
        $.ajax({
            url: "/Progress/SubmitAddStudentsDeclaredMarks",
            type: "POST",
            dataType: 'json',
            data: dataList,
            global: false,
            success: function (response) {
                if (response.status) {
                    toastrSuccess(response.msg);
                    window.location.href = '/Progress/ExamResult/';
                }
                else {
                    toastrError(response.msg);
                    //window.location.href = '/Progress/ExamResult/';
                }
            },
            error: function (data) {
            }
        });
    };

