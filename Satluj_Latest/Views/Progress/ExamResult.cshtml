    $(document).on('click', '#student-total-score-save', function () {
        var classId = $('#ClassId').val();
        var divisionId = $('#DivisionId').val();
        var examId = $('#ExamId').val();
        if (classId != '' && divisionId != '' && examId != '') {
            $.ajax({
                url: '/Progress/ViewStudentsTotalScoreViewPage/'  + examId + '~' + classId + '~' + divisionId,
                type: "GET",
                dataType: 'html',
                success: function (data) {
                    $('#model-view-space').html(data);
                    $('#model-view-space').modal('show');
                }
            });
        }
        else {
            $('#model-view-space').modal('hide');
        }
    });

    $(document).on('click', '#btn-Student-total-score-percentage', function () {
        var source = $(this);
        getAllStudentsScoreWIthPercentage(source);
    });

    function getAllStudentsScoreWIthPercentage(source) {
        var dataList = new Object();
        dataList.ClassIdModel = $('#ClassIdModel').val();
        dataList.DivisionIdModel = $('#DivisionIdModel').val();
        dataList.SchoolIdModel = $('#SchoolIdModel').val();
        dataList.ExamIdModel = $('#ExamIdModel').val();
        dataList.list = [];
        $('.cls-tr-classModel').each(function (index, elem) {
            var data = new Object();
            data.StudentId = $(this).attr('data-StudentId');
            if ($(this).find('.cls-MarkObtained').val() != '')
                data.MarkObtained = parseFloat($(this).find('.cls-MarkObtained').val()).toFixed(2);
            else
                data.MarkObtained = 0;
            if ($(this).find('.cls-mark-MarkPercentage').val() != '')
                data.MarkPercentage = parseFloat($(this).find('.cls-mark-MarkPercentage').val()).toFixed(2);
            else
                data.MarkPercentage = 0;
            data.StudentName = '';
            dataList.list.push(data);
        });
        console.log(dataList);
        $.ajax({
            url: "/Progress/SubmitStudentsTotalScoreAndPercentage",
            type: "POST",
            dataType: 'json',
            data: dataList,
            global: false,
            success: function (response) {
                if (response.status) {
                    toastrSuccess(response.msg);
                    $('#model-view-space').modal('hide');
                }
                else {
                    toastrError(response.msg);
                }
            },
            error: function (data) {
            }
        });
    };


</script>