@model Satluj_Latest.Models.CoScholasticAreaModel

@{
    ViewBag.Title = "CoScholasticArea";
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
}

@Html.HiddenFor(z => z.SchoolId)
@Html.HiddenFor(z => z.RegionId)

<div class="row">
    <div class="col-md-12">
        <h3>Co-Scholastic Area</h3>

        <form asp-action="AddCoScholasticArea"
              asp-controller="Progress"
              method="post"
              id="form-teacher-add">

            @Html.AntiForgeryToken()

            <div class="row">

                <div class="form-group col-sm-3">
                    <label>Region :</label>
                    <select asp-for="RegionId"
                            asp-items="ViewBag.Regions"
                            class="form-control slct-region-dropdwn1"
                            data-live-search="true"
                            style="width:100%; min-width:180px;">
                        <option value="">--Choose--</option>
                    </select>

                    <span asp-validation-for="RegionId" class="text-danger"></span>

                </div>

                <div class="form-group col-sm-3">
                    <label>Item :</label>
                    @Html.TextBoxFor(
                        m => m.Item,
                        new { @class = "form-control", placeholder = "Co-Scholastic Area" })
                    @Html.ValidationMessageFor(m => m.Item)
                </div>

                <div class="form-group col-sm-3">
                    <label></label>
                    <button type="submit"
                            class="btn pay-now-btn"
                            style="margin-top:9%">
                        <i class="fa fa-save"></i> Save
                    </button>
                </div>

            </div>
        </form>

        <div class="table-responsive">
            @Html.Partial("~/Views/Progress/_pv_Co-ScholasticAreaList.cshtml", Model)
        </div>
    </div>
</div>

<div class="modal fade" id="modalCoScholasticEdit"></div>
<script>
    $(function () {
        $(".co-scholastic-area-list").DataTable();
    });

    $(document).on("submit", "#form-teacher-add", function (e) {
        e.preventDefault();

        $.ajax({
            url: $(this).attr("action"),
            type: "POST",
            data: $(this).serialize(),
            success: function (result) {
                if (result.status) {
                    toastrSuccess(result.msg);
                } else {
                    toastrError(result.msg);
                }
                window.location.href = '/Progress/CoScholasticArea/';
            },
            error: function () {
                toastrError("Failed!");
            }
        });
    });
</script>
