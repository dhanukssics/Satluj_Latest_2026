
@model Satluj_Latest.Models.StudentExamTotalSccore
@{
        bool IsAdmin = ViewBag.IsAdmin;
    int count = 1;
}

@Html.HiddenFor(z => z.SchoolIdModel, new { Value = @Model.SchoolIdModel })
@Html.HiddenFor(z => z.ClassIdModel, new { Value = @Model.ClassIdModel })
@Html.HiddenFor(z => z.DivisionIdModel, new { Value = @Model.DivisionIdModel })
@Html.HiddenFor(z => z.ExamIdModel, new { Value = @Model.ExamIdModel })
<div class="modal-dialog modal-lg" role="document">

    <div class="modal-content">
        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            <h4 class="modal-title" id="myModalLabel">Add Students Scores </h4>
        </div>
        <div class="modal-body">
            <div class="table-responsive">
                <table class="table account-table" id="tbstdMarkList">
                    <tr id="thead">
                        <th style="color: black;">
                            Sl.No
                        </th>
                        <th style="color: black;">
                            Student Name
                        </th>

                        <th style="color: black;">
                            Total Mark Obtained
                        </th>

                        <th style="color: black;">
                            Percentage
                        </th>
                    </tr>
                    <tbody id="bodyTable">

                        @foreach (var item in Model.list)
                        {
                            <tr data-id="tbRowAmount" style="color:black;" data-StudentId="@item.StudentId" class="cls-tr-classModel">
                                <td style="width:10%;">
                                    @count
                                </td>
                                <td style="width:50%;">
                                    @item.StudentName
                                </td>
                                <td style="width:40%;">
                                    @if (item.MarkObtained == 0)
                                    {
                                        <div>
                                            <input type="number" value="@String.Format("{00}", item.MarkObtained)" style="color:black; " class="cls-MarkObtained" id="@count" />
                                        </div>
                                    }
                                    else
                                    {

                                        <div>
                                            @if (IsAdmin == true)
                                            {
                                                <input type="number" value="@String.Format("{00}", item.MarkObtained)" style="color:black; " class="cls-MarkObtained" id="@count" />
                                            }
                                            else
                                            {
                                                <input type="number" value="@String.Format("{00}", item.MarkObtained)" style="color:black; " class="cls-MarkObtained" readonly id="@count" />
                                            }
                                        </div>
                                    }
                                </td>

                                <td style="width:40%;">
                                    @if (item.MarkPercentage == 0)
                                    {
                                        <div>
                                            <input type="number" value="@String.Format("{00}", item.MarkPercentage)" style="color:black; " class="cls-mark-MarkPercentage" id="@count" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div>
                                            @if (IsAdmin == true)
                                            {
                                                <input type="number" value="@String.Format("{00}", item.MarkPercentage)" style="color:black; " class="cls-mark-MarkPercentage" id="@count" />
                                            }
                                            else
                                            {
                                                <input type="number" value="@String.Format("{00}", item.MarkPercentage)" style="color:black; " class="cls-mark-MarkPercentage" readonly id="@count" />
                                            }
                                        </div>
                                    }
                                </td>
                            </tr>
                            count = count + 1;
                        }

                    </tbody>
                </table>
                <div class="modal-footer">
                    <button type="button" id="btn-Student-total-score-percentage" style="width: 100%;" class="btn pay-now-btn">Save</button>
                </div>

            </div>
        </div>
    </div>
</div>
