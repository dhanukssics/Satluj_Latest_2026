
@model Satluj_Latest.Models.ExamDeclarationModel
@{
    long schoolId = Model.SchoolId;
    var data = new Satluj_Latest.Data.School(schoolId).GetAllDeclaredExamDetails();
    int x = 1;
        bool IsAdmin = ViewBag.IsAdmin;
}
<table class="table custome-table declared-exam-list">
    <thead>
        <tr>
            <th>
                Sl No
            </th>
            <th>
                Exam Name - Term
            </th>
            <th>
                Class
            </th>
            <th>
                Start
            </th>
            <th>
                End
            </th>
            <th></th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in data)
        {
            <tr>
                <td>@x</td>
                <td>@item.ExamName -- @item.TermName</td>
                <td>@item.ClassName</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>
                    @if (IsAdmin == true)
                    {
                        <button class="delete-class-tr btn btn-peek" data-exam="@item.Id"><i class="fa fa-trash"></i></button>
                        <button class="edit-class-tr btn btn-peek" data-exam="@item.Id"><i class="fa fa-edit"></i></button>
                    }
                    <a href="/Progress/ExamTimeTableViewPrint/@item.Id" target="_blank" class="btn pay-now-btn " data-toggle="model"><i class="fa fa-table"></i> Time Table</a>
                </td>
                <td>
                    <button class="btn pay-now-btn" id="area-id" data-regionid="@item.Id" onclick="examOnclick(@item.Id)"><i class="fa"></i> Add Subjects </button>
                </td>
            </tr>
            x = x + 1;
        }
    </tbody>
</table>
