                        <thead style="text-transform:uppercase; font-size:15px;">
                            <tr>
                                <th rowspan="2">Subjects</th>
                                <th colspan="@colmSpace">Term I</th>
                                <th colspan="@colmSpace">Term II</th>
                            </tr>
                            <tr>
                                @foreach (var terms in Model.TermDataList)
                                {

                                    totalScore = 0;
