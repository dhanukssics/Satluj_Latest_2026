                                        {
                                            int avoidScholasticTotalFromGrand = 0;
                                            totalScore = 0;
                                            foreach (var item in ScholasticList) // Full Scholastics out of Marks
                                            {
                                                if (item.TotalScore != string.Empty && item.TotalScore != "" && avoidScholasticTotalFromGrand != 4)
                                                {
                                                    totalScore = totalScore + Convert.ToInt32(item.TotalScore);
                                                }
                                                <th>@item.TotalScore</th>
                                                avoidScholasticTotalFromGrand = avoidScholasticTotalFromGrand + 1;
                                            }
                                            <th>@totalScore</th>
                                            <th></th>
                                            TotalScoreOfTerms.Add(totalScore);
                                        }
                                    </tr>
                                </thead>
