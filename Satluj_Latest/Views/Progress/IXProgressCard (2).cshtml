                                                {
                                                    totalMark = totalMark;

                                                }
                                                else
                                                {
                                                    totalMark = totalMark + tot;
                                                    totalOutOff = totalOutOff + TotalScoreOfTerms[count];
                                                    count = count + 1;
                                                }
                                                //totalMark = totalMark + tot;
                                                //totalOutOff = totalOutOff + TotalScoreOfTerms[count];
                                                //count = count + 1;
                                            }
                                        </tr>
                                    }
                                    @*COMPUTER SCIENCE*@
                                 
                                    @if (Model.csList.Count() > 0 && Model.csList != null)
                                    {
                                        foreach (var cslist_1 in Model.csList)
                                        {




                                            decimal first = Convert.ToDecimal(cslist_1.PracticalScore) + Convert.ToDecimal(cslist_1.TheoryScore);
                                            decimal second = first * 2;//this variable is declared for displaying grade-Razi 28/03/2022
                                            decimal x = Convert.ToDecimal(cslist_1.PracticalScore);
                                            decimal y = Convert.ToDecimal(cslist_1.PracticalTotal);
                                            decimal p = Convert.ToDecimal(cslist_1.TheoryScore);
                                            decimal q = Convert.ToDecimal(cslist_1.TheoryTotal);

                                            var grade1 = "";
                                            <tr>
                                                <td align="left">@cslist_1.SubjectName.ToUpper()</td>
                                                @if (cslist_1.PracticalScore == "0")
                                                {
                                                    <td colspan="3">-</td>
                                                }
                                                else
                                                {
                                                    @*<td colspan="3">Practical @Model.csList[0].PracticalScore / @Model.csList[0].PracticalTotal</td>*@
