                            <h3 align="center" style="padding:0px; margin:0px;">@Model.ReportName</h3>
                            <p align="center" style="font-size:12px; margin-bottom:0px; margin-top:5px;">
                                @*14px*@
                                @*@Model.SchoolName
                                    <br />*@
                                @Model.SchoolAdddress &nbsp;&nbsp;
                                <br />
                                Email: satlujps@yahoo.co.in @*@Model.SchoolEmail*@ &nbsp;&nbsp;&nbsp;
                                <br />
                                Website: @Model.SchoolWebsite
                            </p>
                        </div>
                    </th>
                </tr>

                <tr>
                    <th colspan="2">
                        <h3 style="margin:0; padding:0; margin-left: 65px;">
                            Academic Performance
                            <br />
