                                                }
                                                @if (cslist_1.TheoryScore == "0")
                                                {
                                                    <td colspan="3">-</td>
                                                }
                                                else
                                                {
                                                    @*<td colspan="3">Theory @Model.csList[0].TheoryScore / @Model.csList[0].TheoryTotal</td>*@
