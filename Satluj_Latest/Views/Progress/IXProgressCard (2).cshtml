                                Date of Birth: @Model.DateOfBirth
                                <br />
                                Class: @Model.ClassDivision
                            </h4>
                        </div>
                        <img src="@Model.StudentImage" style="width:65px; height:65px; margin-left:300px;" />
                    </th>
                </tr>
                @*--------------------------------------------------------------------------------------------------*@
                @if (Model.IsOneTerm == true) // One Term Progress Card
