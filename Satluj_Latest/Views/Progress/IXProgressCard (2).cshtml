    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>Report Card - Satluj School</title>
</head>
<body style="font-family:Arial;">
    @*--------------------PRINT BUTTON----------------------------------------------*@
    @*<div style="height:30px;">*@
    <button type="button" class="btn btn-success btn-style" id="btn-print" style="width: 200px;background-color: #7c89ad; position:absolute; right:20px; top:20px; width: 100px;
     padding: 10px; color: rgb(255, 255, 255); background-color: rgb(124, 137, 173); position: absolute; right: 20px; top: 20px; border: none; display: block; z-index: 999;   visibility: visible;cursor: pointer;" onclick="myFunction()">
        Print
    </button>
    @*</div>*@
    @*--------------------PRINT BUTTON----------------------------------------------*@
    <div class="report-card" style="box-sizing:border-box;">
        <table style="width:100%; font-size:12px;">
            @*15px*@
            <tbody>
                <tr>
                    <th colspan="2" align="left">
