                                                }

                                                <td colspan="1">@Convert.ToInt32(first) </td>
                                                @if (first > 90)
                                                {
                                                    grade1 = "A1";
                                                }
                                                else if (80 < first && first < 91)
                                                {
                                                    grade1 = "A2";
                                                }
                                                else if (70 < first && first < 81)
                                                {
                                                    grade1 = "B1";
                                                }
                                                else if (60 < first && first < 71)
                                                {
                                                    grade1 = "B2";
                                                }
                                                else if (50 < first && first < 61)
                                                {
                                                    grade1 = "C1";
                                                }
                                                else if (40 < first && first < 51)
                                                {
                                                    grade1 = "C2";
                                                }
                                                else if (32 < first && first < 41)
                                                {
                                                    grade1 = "D";
                                                }
                                                else
                                                {
                                                    grade1 = "E";
                                                }
                                                @*

                    this is done, since information technology mark has been changed to out of 50, it was previously for out of 100 - Razi 28/03/2022

                                                *@

                                                @*@if (second > 90)
                    {
                        grade1 = "A1";
                    }
                    else if (80 < second && second < 91)
                    {
                        grade1 = "A2";
                    }
                    else if (70 < second && second < 81)
                    {
                        grade1 = "B1";
                    }
                    else if (60 < second && second < 71)
