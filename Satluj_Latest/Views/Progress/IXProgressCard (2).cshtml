                                            {
                                                var data = terms.scholasticList.ToList();
                                                decimal tot = 0;
                                                var grade = "";
                                                int avoidSchTotalForGrand = 0;
                                                foreach (var result in data)
                                                {
                                                    var areaName = result.ScolasticArea;
                                                    var areaviseData = ((IEnumerable<dynamic>)result.subjectList).Where(X => X.SubjectName == subjects.SubjectName).FirstOrDefault();
                                                    decimal zz = Convert.ToDecimal(areaviseData.Mark);
                                                    decimal zz2 = Math.Round(zz, MidpointRounding.AwayFromZero);
                                                    if (avoidSchTotalForGrand != 4)
                                                    {
                                                        if (areaName == "PT")
                                                        {
                                                            zz2 = Math.Round((zz * 5) / 40);

                                                            tot = tot + zz2;
                                                        }

                                                        else
                                                        {

                                                            tot = tot + zz2;
                                                        }
                                                    }
                                                    if (areaviseData.Mark == "0")
                                                    {
                                                        <td>-</td>
                                                    }
                                                    else
                                                    {
                                                        @*<td>@areaviseData.Mark</td>*@
                                                        @*<td></td>*@
                                                        <td>@Convert.ToInt32(zz2)</td>
                                                    }
                                                    avoidSchTotalForGrand = avoidSchTotalForGrand + 1;
                                                }
                                                <td>@Convert.ToInt32(tot)</td>
                                                var persentage = Math.Round(((tot / TotalScoreOfTerms[count]) * 100), MidpointRounding.AwayFromZero);
                                                if (persentage > 90)
                                                {
                                                    grade = "A1";
                                                }
                                                else if (80 < persentage && persentage < 91)
                                                {
                                                    grade = "A2";
                                                }
                                                else if (70 < persentage && persentage < 81)
                                                {
                                                    grade = "B1";
                                                }
                                                else if (60 < persentage && persentage < 71)
                                                {
                                                    grade = "B2";
                                                }
                                                else if (50 < persentage && persentage < 61)
                                                {
                                                    grade = "C1";
                                                }
                                                else if (40 < persentage && persentage < 51)
                                                {
                                                    grade = "C2";
                                                }
                                                else if (32 < persentage && persentage < 41)
                                                {
                                                    grade = "D";
                                                }
                                                else
                                                {
                                                    grade = "E";
                                                }
                                                <td>@grade</td>
