                        grade1 = "C2";
                    }
                    else if (32 < second && second < 41)
                    {
                        grade1 = "D";
                    }
                    else
                    {
                        grade1 = "E";
                    }*@
                                                <td colspan="1">@grade1</td>
                                            </tr>
                                        }

                                    }@*COMPUTER SCIENCE*@

                                </tbody>
                            </table>
                        </th>
                    </tr>

                    <tr colspan="2">
                        <th>
