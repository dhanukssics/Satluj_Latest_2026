@model Satluj_Latest.Models.ExamDeclarationModel

@{
    ViewData["Title"] = "ExamDeclaration";
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
}

@Html.HiddenFor(m => m.SchoolId)

<div class="row">
    <div class="col-md-12">
        <h3 style="margin-top: 5px;">Exam Declaration</h3>

        <form id="form-teacher-add"
              asp-controller="Progress"
              asp-action="AddDeclaredExams"
              method="post">

            <div class="row">

                <div class="form-group col-sm-3">
                    <label>Class :</label>
                    <select asp-for="ClassId"
                            asp-items="ViewBag.ClassList"
                            class="form-control pv_class-drop-down"
                            id="classDataDropdown">
                        <option value="">--Choose--</option>
                    </select>

                    <span asp-validation-for="ClassId" class="text-danger"></span>


                </div>

                <div class="form-group col-sm-3">
                    <label>Terms :</label>
                    @Html.DropDownListFor(
                                        m => m.TermId,
                                        new SelectList(new[] {
                                        new { value = 0, text = "--select term--" }
                                        }, "value", "text"),
                                        new { @class = "form-control term_Select", disabled = "disabled" })
                    @Html.ValidationMessageFor(m => m.TermId)
                </div>

                <div class="form-group col-sm-3">
                    <label>Exam Name :</label>
                    @Html.TextBoxFor(m => m.ExamName,
                                        new { @class = "form-control", placeholder = "Exam Name" })
                    @Html.ValidationMessageFor(m => m.ExamName)
                </div>
            </div>

            <div class="row">

                <div class="form-group col-sm-3">
                    <label>Start Date :</label>
                    @Html.TextBoxFor(m => m.StartDateString,
                                        new { @class = "form-control date-cashentry-add" })
                    @Html.ValidationMessageFor(m => m.StartDateString)
                </div>

                <div class="form-group col-sm-3">
                    <label>End Date :</label>
                    @Html.TextBoxFor(m => m.EndDateString,
                                        new { @class = "form-control date-cashentry-add" })
                    @Html.ValidationMessageFor(m => m.EndDateString)
                </div>

                <div class="form-group col-sm-3">
                    <button type="submit"
                            class="btn pay-now-btn"
                            id="area-id"
                            style="margin-top: 9%;">
                        <i class="fa fa-save"></i> Save
                    </button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            @await Html.PartialAsync(
                        "~/Views/Progress/_pv_DeclaredExamList.cshtml", Model)
        </div>
    </div>
</div>

<div class="modal fade" id="modalDeclaredExamEdit" tabindex="-1"></div>

@section Scripts {
<script>

    $('.date-cashentry-add').datepicker({
        format: 'dd-mm-yyyy',
        autoclose: true,
        todayHighlight: true
    });

    $(document).ready(function () {
        var today = new Date();
        var dd = String(today.getDate()).padStart(2, '0');
        var mm = String(today.getMonth() + 1).padStart(2, '0');
        var yyyy = today.getFullYear();
        $('.date-cashentry-add').val(dd + '-' + mm + '-' + yyyy);
    });

    $('#form-teacher-add').on('submit', function (e) {
        e.preventDefault();

        $.ajax({
            url: $(this).attr('action'),
            type: 'POST',
            data: $(this).serialize(),
            success: AddExamDeclarationSuccess,
            error: AddExamDeclarationFailure
        });
    });

    function AddExamDeclarationSuccess(result) {
        if (result.status) {
            toastrSuccess(result.msg);
        } else {
            toastrError(result.msg);
        }
        window.location.href = '/Progress/ExamDeclaration/';
    }

    function AddExamDeclarationFailure() {
        toastrError("Failed!");
        window.location.href = '/Progress/ExamDeclaration/';
    }

    $(function () {
        $(".declared-exam-list").DataTable();
    });

    function examOnclick(id) {
        if (id && id !== '0') {
            window.location.href = "/Progress/DeclaredExamSubject/" + id;
        }
    }

</script>
}
