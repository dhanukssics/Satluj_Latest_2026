@model Satluj_Latest.Models.FeeAlertDataModel

<div class="col-md-12 col-md-offset-1">
    <div class="email-setup-main">

        <form id="form-login"
              asp-action="AddNewFeeAlertDate"
              asp-controller="School"
              method="post">

            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="cust-label">Fee Alert Date</label>
                <p>
                    Automatically send alert messages to all students
                    who have not paid the bills before this date.
                </p>

                <span class="col-md-4">
                    <input asp-for="AlertDate"
                           class="form-control"
                           placeholder="Select Date"
                           autocomplete="off" />
                    <span asp-validation-for="AlertDate"></span>
                </span>
            </div>

            <div class="form-group">
                <span class="col-md-12" style="float:left; margin-top:15px;">
                    <button type="submit" class="btn pay-now-btn">Add</button>
                </span>
            </div>

        </form>
    </div>
</div>
<script>
    $("#form-login").submit(function (e) {
        e.preventDefault();

        $.ajax({
            url: this.action,
            type: "POST",
            data: $(this).serialize(),
            success: AddNewFeeAlertDateSuccess,
            error: AddNewFeeAlertDateFailed
        });
    });
 
    $('#AlertDate').datepicker({
        format: 'mm-dd-yyyy',
        autoclose: true,
        todayHighlight: true
    });

    $(document).ready(function () {
        $('#AlertDate').val('');
    });


</script>
