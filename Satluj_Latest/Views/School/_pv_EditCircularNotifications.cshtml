@model Satluj_Latest.Models.AddCircularNotification

<form id="form-login"
      asp-controller="School"
      asp-action="SubmitEditCircularNotifications"
      method="post"
      enctype="multipart/form-data">

    <input type="hidden" asp-for="CircularId" />
    <input type="hidden" asp-for="FilePath" />

    <div class="col-md-4 col-md-offset-4" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">Edit Circular Notifications</h4>
            </div>

            <div class="modal-body">

                <!-- Document Date -->
                <div class="form-group">
                    <label class="cust-label">Document Date</label>
                    <div class="calendar-inp">
                        <input asp-for="DocumentDateString"
                               class="form-control cust-inp"
                               id="DocumentDateString" />
                        <i class="fa fa-calendar"></i>
                        <span asp-validation-for="DocumentDateString" class="text-danger"></span>
                    </div>
                </div>

                <!-- File Upload -->
                <div class="form-group">
                    <label class="cust-label">File</label>
                    <div class="uploader-box td-uploder">
                        <input type="file"
                               name="uploadFile"
                               class="upload-file upload-clean-Formats-dev-edit" />
                        <button type="button" class="btn-link btn-link-pink">
                            <i class="fa fa-cloud-upload"></i>
                        </button>
                    </div>
                </div>

                <!-- Circular Head -->
                <div class="form-group">
                    <label class="cust-label">Circular Head</label>
                    <textarea asp-for="DocumentHead"
                              class="form-control cust-inp"></textarea>
                    <span asp-validation-for="DocumentHead" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="form-group">
                    <label class="cust-label">Description</label>
                    <textarea asp-for="DocumentDetails"
                              class="form-control cust-inp"></textarea>
                    <span asp-validation-for="DocumentDetails" class="text-danger"></span>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    Cancel
                </button>
                <button type="submit" class="btn pay-now-btn">
                    Save
                </button>
            </div>

        </div>
    </div>
</form>
<script>
    $(document).on("submit", "#form-login", function (e) {
        e.preventDefault();

        var formData = new FormData(this);

        $.ajax({
            url: $(this).attr("action"),
            type: "POST",
            data: formData,
            contentType: false,
            processData: false,
            success: function (response) {
                CircularNotificationsEditSuccess(response);
            },
            error: function (xhr) {
                CircularNotificationsEditFailed(xhr);
            }
        });
    });
</script>
