@model Satluj_Latest.Models.StudentModel

<form id="form-login"
      asp-action="AddNewStudentParentInfo"
      asp-controller="School"
      method="post">

    <input type="hidden" asp-for="studentId" />
    <input type="hidden" asp-for="classId" />
    <input type="hidden" asp-for="divisionId" />

    <!-- Names -->
    <div class="row">
        <div class="col-sm-12">

            <div class="form-group col-sm-4">
                <label asp-for="FatherName"></label>
                <input asp-for="FatherName" class="form-control" readonly />
                <span asp-validation-for="FatherName"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="MotherName"></label>
                <input asp-for="MotherName" class="form-control" readonly />
                <span asp-validation-for="MotherName"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="GuardianName"></label>
                <input asp-for="GuardianName" class="form-control" readonly />
                <span asp-validation-for="GuardianName"></span>
            </div>

        </div>
    </div>

    <!-- Education -->
    <div class="row">
        <div class="col-sm-12">

            <div class="form-group col-sm-4">
                <label asp-for="FatherEducation"></label>
                <input asp-for="FatherEducation" class="form-control" readonly />
                <span asp-validation-for="FatherEducation"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="MotherEducaton"></label>
                <input asp-for="MotherEducaton" class="form-control" readonly />
                <span asp-validation-for="MotherEducaton"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="GuardianEduation"></label>
                <input asp-for="GuardianEduation" class="form-control" readonly />
                <span asp-validation-for="GuardianEduation"></span>
            </div>

        </div>
    </div>

    <!-- Occupation -->
    <div class="row">
        <div class="col-sm-12">

            <div class="form-group col-sm-4">
                <label asp-for="FatherOccupation"></label>
                <input asp-for="FatherOccupation" class="form-control" readonly />
                <span asp-validation-for="FatherOccupation"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="MotherOccupation"></label>
                <input asp-for="MotherOccupation" class="form-control" readonly />
                <span asp-validation-for="MotherOccupation"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="GuardianOccupation"></label>
                <input asp-for="GuardianOccupation" class="form-control" readonly />
                <span asp-validation-for="GuardianOccupation"></span>
            </div>

        </div>
    </div>

    <!-- Contact -->
    <div class="row">
        <div class="col-sm-12">

            <div class="form-group col-sm-4">
                <label asp-for="FatherContact"></label>
                <input asp-for="FatherContact" class="form-control" readonly />
                <span asp-validation-for="FatherContact"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="MotherContact"></label>
                <input asp-for="MotherContact" class="form-control" readonly />
                <span asp-validation-for="MotherContact"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="GuardianContact"></label>
                <input asp-for="GuardianContact" class="form-control" readonly />
                <span asp-validation-for="GuardianContact"></span>
            </div>

        </div>
    </div>

    <!-- Email -->
    <div class="row">
        <div class="col-sm-12">

            <div class="form-group col-sm-4">
                <label asp-for="FatherEmail"></label>
                <input asp-for="FatherEmail" class="form-control" readonly />
                <span asp-validation-for="FatherEmail"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="MotherEmail"></label>
                <input asp-for="MotherEmail" class="form-control" readonly />
                <span asp-validation-for="MotherEmail"></span>
            </div>

            <div class="form-group col-sm-4">
                <label asp-for="GuardianEmail"></label>
                <input asp-for="GuardianEmail" class="form-control" readonly />
            </div>

        </div>
    </div>

    <!-- Footer -->
    <div class="row">
        <div class="col-sm-12">
            <div class="form-group col-sm-4"></div>
            <div class="form-group col-sm-4"></div>
            <div class="form-group col-sm-4">
                <button type="button"
                        id="parentViewPageCompleteBtnId"
                        class="btn btn-default"
                        data-dismiss="modal">
                    Complete
                </button>
            </div>
        </div>
    </div>

</form>
<script>
    $("#form-login").submit(function (e) {
        e.preventDefault();

        $.ajax({
            url: $(this).attr("action"),
            type: "POST",
            data: $(this).serialize(),
            success: function (res) {
                StudentParentsAddSuccess(res);
            },
            error: function () {
                StudentAddFailed();
            }
        });
    });
</script>
