@model Satluj_Latest.Models.FeeAlertDataModel

<div class="col-md-12 col-md-offset-1" style="margin-bottom:70%; margin-top:3%;">
    <div class="email-setup-main">

        <form id="form-login"
              asp-action="AddFeeAccountHeadData"
              asp-controller="School"
              method="post">

            <div class="form-group">
                <label>Fee Income Head Name</label>

                <input asp-for="FeeIncomeHead.AccountHead"
                       id="feeIncomeHeadId"
                       class="form-control"
                       style="width:50%;"
                       placeholder="Head"
                       autocomplete="off" />

                <span asp-validation-for="FeeIncomeHead.AccountHead"
                      class="text-danger"></span>
            </div>

            <div class="form-group">
                <span class="col-md-12" style="float:left; margin-top:15px;">
                    <button type="submit" class="btn pay-now-btn">
                        Add
                    </button>
                </span>
            </div>

        </form>

    </div>
</div>
@section Scripts {

    <script>
        $(document).ready(function () {
            $('#feeIncomeHeadId').val('');
        });

        $("#form-login").submit(function (e) {
            e.preventDefault();

            $.ajax({
                url: $(this).attr("action"),
                type: "POST",
                data: $(this).serialize(),
                success: function (result) {
                    AddFeeIncomeHeadSuccess(result);
                },
                error: function () {
                    AddFeeIncomeHeadFailed();
                }
            });
        });
    </script>
}
