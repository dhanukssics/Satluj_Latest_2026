@model Satluj_Latest.Models.ExamsModel

<style>
    .border-design {
        border: 1px solid black !important;
    }
</style>

<form id="form-add-exam"
      asp-action="SubmitAddExam"
      asp-controller="School"
      method="post">

    <input asp-for="SchoolId" type="hidden" />
    <input asp-for="ClassId" type="hidden" />

    <div class="col-lg-6 col-lg-offset-4" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
                <h4 class="modal-title">Add New Exams</h4>
            </div>

            <div class="modal-body">

                <div class="row">
                    <div class="col-sm-6">
                        <div class="form-group">
                            <label>Class</label><span class="text-danger">*</span>

                            <select asp-for="ClassId"
                                    asp-items="ViewBag.ClassList"
                                    class="form-control slct-alldivisions-dropdwn border-design"
                                    data-live-search="true">
                                <option value="">--Choose--</option>
                            </select>

                            <span asp-validation-for="ClassId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div class="form-group">
                            <label>Name</label><span class="text-danger">*</span>

                            <input asp-for="ExamName"
                                   class="form-control border-design"
                                   placeholder="Name"
                                   autocomplete="off" />

                            <span asp-validation-for="ExamName" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-sm-6 calendar-inp pos_icon_adj form-group">
                        <label>Start Date</label><span class="text-danger">*</span>

                        <input asp-for="StartDateString"
                               class="form-control date-exam-add border-design"
                               placeholder="Select Date"
                               autocomplete="off" />

                        <span asp-validation-for="StartDateString" class="text-danger"></span>
                    </div>

                    <div class="col-sm-6 calendar-inp pos_icon_adj form-group">
                        <label>End Date</label><span class="text-danger">*</span>

                        <input asp-for="EndDateString"
                               class="form-control date-exam-add border-design"
                               placeholder="Select Date"
                               autocomplete="off" />

                        <span asp-validation-for="EndDateString" class="text-danger"></span>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        id="btn-dummy-addExam"
                        class="btn pay-now-btn">
                    Save
                </button>
            </div>

        </div>
    </div>
</form>
@section Scripts {

    <script>
        $(document).ready(function () {

            // Set today's date
            var today = new Date();
            var dd = String(today.getDate()).padStart(2, '0');
            var mm = String(today.getMonth() + 1).padStart(2, '0');
            var yyyy = today.getFullYear();

            $('.date-exam-add').val(dd + '-' + mm + '-' + yyyy);

            $('.date-exam-add').datepicker({
                format: 'mm-dd-yyyy',
                autoclose: true,
                todayHighlight: true
            });

            $("#btn-dummy-addExam").click(function () {
                $.ajax({
                    url: $("#form-add-exam").attr("action"),
                    type: "POST",
                    data: $("#form-add-exam").serialize(),
                    success: function (result) {
                        ExamAddSuccess(result);
                    },
                    error: function () {
                        ExamAddFailed();
                    }
                });
            });
        });
    </script>

}
