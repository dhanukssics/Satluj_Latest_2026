@model Satluj_Latest.Models.AddCircularNotification

<form id="form-login"
      asp-action="SubmitAddCircularNotifications"
      asp-controller="School"
      method="post"
      enctype="multipart/form-data">

    <div class="col-md-4 col-md-offset-4" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <button type="button"
                        class="close"
                        data-bs-dismiss="modal"
                        aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">Add Circular Notifications</h4>
            </div>

            <div class="modal-body">

                <!-- Document Date -->
                <div class="form-group">
                    <label class="cust-label">Document Date</label>
                    <div class="calendar-inp row">
                        <div class="col-md-6" style="margin-top:20px;">
                            <i class="fa fa-calendar"
                               style="position:absolute; top:10px; right:25px;"></i>

                            <input asp-for="DocumentDateString"
                                   class="form-control"
                                   autocomplete="off"
                                   placeholder="Select Date" />

                            <span asp-validation-for="DocumentDateString"
                                  class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- File Upload -->
                <div class="form-group">
                    <label class="cust-label">File</label>

                    <div class="uploader-box td-uploder">
                        <input type="file"
                               class="upload-file upload-clean-Formats-dev" />
                        <button type="button" class="btn-link btn-link-pink">
                            <i class="fa fa-cloud-upload"></i>
                        </button>
                    </div>

                    <input asp-for="FilePath" type="hidden" />
                    <span asp-validation-for="FilePath"
                          class="text-danger"></span>
                </div>

                <!-- Circular Head -->
                <div class="form-group">
                    <label class="cust-label">Circular Head</label>
                    <textarea asp-for="DocumentHead"
                              class="form-control cust-inp"></textarea>
                    <span asp-validation-for="DocumentHead"
                          class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="form-group">
                    <label class="cust-label">Description</label>
                    <textarea asp-for="DocumentDetails"
                              class="form-control cust-inp"></textarea>
                    <span asp-validation-for="DocumentDetails"
                          class="text-danger"></span>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-default"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <button type="submit"
                        class="btn pay-now-btn">
                    Save
                </button>
            </div>

        </div>
    </div>
</form>
@section Scripts {
    <script>
        $("#form-login").submit(function (e) {
            e.preventDefault();

            $.ajax({
                url: $(this).attr("action"),
                type: "POST",
                data: $(this).serialize(),
                success: function (result) {
                    CircularNotificationsAddSuccess(result);
                },
                error: function () {
                    CircularNotificationsAddFailed();
                }
            });
        });
    </script>
}

<script>
    $('#DocumentDateString').datepicker({
        format: "dd-mm-yyyy",
        autoclose: true,
        startDate: new Date(),
        todayHighlight: true
    });

    $(document).on('change', '.upload-clean-Formats-dev', function () {

        var formData = new FormData();
        formData.append("documentFile", this.files[0]);

        $.ajax({
            type: "POST",
            url: "/School/DocumentUpload",
            data: formData,
            contentType: false,
            processData: false,
            success: function (response) {
                if (response.status) {
                    $('#FilePath').val(response.userData);
                } else {
                    toastrError('No such Files!');
                }
            }
        });
    });

    function CircularNotificationsAddSuccess(result) {
        if (result.status === true) {
            $('#modalAddCircular').modal('hide');
            RefresData();
            toastrSuccess(result.message);
        } else {
            toastrError("Error");
        }
    }

    function CircularNotificationsAddFailed() {
        $('#modalAddCircular').modal('hide');
        RefresData();
        toastrError('Failed!');
    }
</script>

