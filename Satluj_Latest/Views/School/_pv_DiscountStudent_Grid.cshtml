    @model Satluj_Latest.Models.SchoolModel
@{
    var discounts = new Satluj_Latest.Data.School(Model.schoolId).GetStudentDiscountList().OrderBy(z => z.Student.StundentName).ToList();
}<div class="table-responsive">
    <table class="table custome-table table-student-list">
        <thead>
            <tr>
                @*<th>

                </th>*@
                <th>
                    Name
                </th>
                <th>
                    Class/Division
                </th>
                <th>
                    Fee Name
                </th>
                <th>
                    Discounted Amount
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var discount in discounts)
            {
                <tr class="ng-click-studentDiscount-details" data-studentid="@discount.StudentId">
                    @*@if (discount.student.FilePath != null)
                    {
                        <td class="ng-click-studentDiscount-details">
                            <img src="@discount.student.FilePath" class="user-pic-tab" />
                        </td>
                    }
                    else
                    {
                        <td class="ng-click-studentDiscount-details">
                            <img src="~/Content/img/children-1.gif" class="user-pic-tab" />
                        </td>
                    }*@
                    <td class="ng-click-studentDiscount-details">
                        @discount.Student.StundentName
                    </td>

                    <td class="ng-click-studentDiscount-details">
                        @discount.Student.Class / @discount.Student.Division
                    </td>
                    <td class="ng-click-studentDiscount-details">
                        @discount.Fee
                    </td>
                    <td class="ng-click-studentDiscount-details">
                        @String.Format("{0:0.00}", discount.DiscountAmount)

                    </td>
                    <td>
                        <button class="delete-fee-tr btn btn-peek" data-id="@discount.StudentId" data-feeid="@discount.FeeId"><i class="fa fa-trash "></i></button>
                        <button class="edit-fee-tr pay-now-btn btn" data-id="@discount.StudentId" data-feeid="@discount.FeeId"><i class="fa fa-edit "></i></button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

