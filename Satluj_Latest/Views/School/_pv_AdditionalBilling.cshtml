@model Satluj_Latest.Models.FeeModel

<style>
    .modal-dialog {
        width: 60% !important;
        height: 42% !important;
        margin: 0 auto;
        margin-top: 1.3%;
        padding: 0;
    }

    #form-inputbox tr td,
    #form-inputbox tr,
    .custome-table tr td {
        vertical-align: top !important;
    }
</style>

<div class="modal-dialog" role="document">
    <div class="modal-content">

        <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal">
                <span>&times;</span>
            </button>
            <h4 class="modal-title">Add Payment</h4>
        </div>

        <form id="form-login"
              asp-action="AddAdditionalFeeStudent"
              asp-controller="School"
              method="post">

            <div class="modal-body">
                <div class="table-responsive">

                    <input asp-for="FeeId" type="hidden" />
                    <input asp-for="StudentId" type="hidden" />

                    <table class="table custome-table table-striped"
                           style="margin:0;height:478px;overflow:auto;display:block;">

                        <tr>
                            <th>Particulars</th>
                            <th style="width:20%;text-align:right;">Amount</th>
                        </tr>

                        <tr id="form-inputbox">
                            <td>
                                <input id="autoFeeId"
                                       class="form-control my_form"
                                       placeholder="Fee name"
                                       autocomplete="off"
                                       maxlength="50" />
                            </td>
                            <td style="width:20%;text-align:right;">
                                <input id="Amount"
                                       class="form-control my_form"
                                       placeholder="Amount"
                                       type="number"
                                       autocomplete="off" />
                            </td>
                        </tr>

                        @foreach (var data in new Satluj_Latest.Data.School(Model.SchoolId).GetSpecialFeeList())
                        {
                            <tr>
                                <td>
                                    <span class="addpayment-fee-input"
                                          style="margin-left:15px;">
                                        @data.FeeName
                                    </span>
                                </td>
                                <td style="width:20%;text-align:right;">
                                    <input class="form-control my_form addpayment-fee-input"
                                           data-id="@data.FeeId"
                                           type="number"
                                           autocomplete="off"
                                           placeholder="Amount" />
                                </td>
                            </tr>
                        }

                        <tr id="append-div-dev"></tr>

                    </table>
                </div>
            </div>

            <div class="modal-footer" style="padding:13px;">
                <button type="button" class="btn btn-default" data-dismiss="modal">
                    Cancel
                </button>

                <button type="button"
                        id="save-add-payment"
                        class="btn pay-now-btn">
                    Add
                </button>
            </div>

        </form>

    </div>
</div>
@section Scripts {

    <script>
        $(document).ready(function () {
            $('#FeeId').val(0);
            FeeHead();
        });

        function FeeHead() {
            $.ajax({
                url: '/School/GetAllFeeHead',
                type: "POST",
                dataType: 'json',
                success: function (data) {
                    var options = {
                        data: data.result,
                        list: {
                            match: { enabled: true }
                        }
                    };
                    $("#autoFeeId").easyAutocomplete(options);
                }
            });
        }

        $("#save-add-payment").click(function () {
            $.ajax({
                url: $("#form-login").attr("action"),
                type: "POST",
                data: $("#form-login").serialize(),
                success: function (result) {
                    AddFeeStudentSuccess(result);
                },
                error: function () {
                    ajaxFailure();
                }
            });
        });
    </script>

}
