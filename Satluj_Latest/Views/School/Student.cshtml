    $(document).on('keyup', '#studentAdmissionNo', function () { //Archana : For check admission number 09-Aug-17
        var source = $(this);
        $.ajax({
            url: '/School/CheckAdmissionNo?text=' + $(source).val(),
            type: "GET",
            global: false,     // this makes sure ajaxStart is not triggered
            dataType: 'json',
            success: function (data) {
                if (data.Status) {
                    $('#spn-error-admissionNo').text(data.Message);
                    $('#ValidateForm').val(true);
                    $('#spn-error-admissionNo').show();
                    $('#studentStudentAdd').css({ 'cursor': 'default', 'pointer-events': 'none', 'opacity': '.8' }); //Avoid Save Buttion Click Vishnu-Button
                }
                else {
                    $('#ValidateForm').val(false);
                    $('#spn-error-admissionNo').hide();
                    $('#studentStudentAdd').css({ 'cursor': 'pointer', 'pointer-events': 'initial', 'opacity': '1' });
                }
            }
        });
    });


