@model Satluj_Latest.Models.SchoolModel
@{
    ViewBag.Title = "Student";
    Layout = "~/Views/Shared/_SchoolAdminLayout.cshtml";
    var students = new Satluj_Latest.Data.School(Model.schoolId).GetStudentDetails().OrderBy(z => z.StundentName).ToList();
}

<style>
    span {
