        if (classId != '') {
            // resetDropDown('Class');
            $.ajax({
                url: '/Data/LoadDivision?id=' + classId,
                type: "GET",
                success: function (result) {
                    if (result.list.length > 0) {
                        $("#division-drop-down").html(""); // clear before appending new list
                        $("#division-drop-down").append($('<option></option>').val("").html('-- Select Division --'));
                            $.each(result.list, function (i, item) {
                                    $("#division-drop-down").append(
                                        $('<option></option>').val(item.value).html(item.text)
                                    );
                                });
                        $("#division-drop-down").prop("disabled", false);
                    }
                    else {
                        // resetDropDown('Class');
                        $("#division-drop-down").html(""); // clear before appending new list
                        $("#division-drop-down").append($('<option></option>').val("").html('-- No Division Found --'));
                        $("#division-drop-down").prop("disabled", true);
                    }
                }
            });
        }
        else {
            //  resetDropDown('Class');
        }
        //-----------------------------------------
        $.ajax({
            url: '/School/GetUserListByClassDiv/' + classId + '~' + 0,
            dataType: 'html',
            success: function (data) {
                $('#pv-table').html('');
                $('#pv-table').html(data);
                IntializeDataTable();
            },
        });
    });
    $(document).on('click', '.delete-student-td', function () {

        var source = $(this);

        swal({
            title: "Are you sure?",
            text: "You will not be able to undo this !",
            type: "warning",
            showCancelButton: true,
            confirmButtonColor: "#DD6B55",
            confirmButtonText: "Yes, delete it!",
            cancelButtonText: "No, cancel!",
            closeOnConfirm: true,
            closeOnCancel: true
        },
function (isConfirm) {
    if (isConfirm) {


        $.ajax({
            url: '/School/DeleteStudent/' + $(source).attr('data-studentid'),
            type: "GET",
            dataType: 'json',
            success: function (data) {

                if (data.status) {
                    toastrSuccess(data.msg);

                    setTimeout(function () {
                        $.ajax({
                            url: '/School/GetUserListByClassDiv/' + '0' + '~' + data.division,
                            dataType: 'html',
                            success: function (data) {
                                $('#pv-table').html('');
                                $('#pv-table').html(data);
                                IntializeDataTable();
                            },
                        });
                    }, 250);
                }
                else {
                    toastrError(data.msg);
                }
            }
        });

        //swal("Deleted!", "Your imaginary file has been deleted.", "success");
    }
    //else {
    //    swal("Cancelled", "Your imaginary file is safe :)", "error");
    //}
});
