                </select>
            </div>
            <div class="col-sm-4">
                <div class="form-group text-right" style="margin-top: 24px;">
                    <button class="btn pay-now-btn" id="addStudent" onclick="AddStudentNewStyle()"><i class="fa fa-plus"></i> Add Student</button>
                </div>
            </div>
        </div>
        <div id="pv-table">

        </div>
    </div><!-- end of col md 12 -->
</div>


<!-- Modal -->
<div class="modal fade" id="addStudentModel">
</div>
<div class="modal fade" id="editStudentModel">
</div>




