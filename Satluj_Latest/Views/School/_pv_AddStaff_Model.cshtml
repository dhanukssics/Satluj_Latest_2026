@model Satluj_Latest.Models.StaffModels

@{
    var rolesList = Model.RolesList;
}


<div class="modal-dialog modal-lg" role="document">

    <style>
        span {
            color: red;
        }
    </style>

    <form id="form-teacher-add"
          asp-action="AddStaff"
          asp-controller="School"
          method="post">

        <input type="hidden" asp-for="Password" />
        <input type="hidden" asp-for="RoleData" />

        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
                <h4 class="modal-title">Add Staff</h4>
            </div>

            <div class="modal-body">

                <!-- Name / Email -->
                <div class="row">
                    <div class="col-sm-6">
                        <label asp-for="Name"></label>
                        <input asp-for="Name" class="form-control" autocomplete="off" />
                        <span asp-validation-for="Name"></span>
                    </div>

                    <div class="col-sm-6">
                        <label asp-for="emailId"></label>
                        <input asp-for="emailId" class="form-control" autocomplete="off" />
                        <span asp-validation-for="emailId"></span>
                        <span id="spn-error-email-teacher"></span>
                    </div>
                </div>

                <!-- DOB / Contact / Designation -->
                <div class="row mt-2">
                    <div class="col-sm-3">
                        <label asp-for="DOBstring"></label>
                        <input asp-for="DOBstring" class="form-control" />
                        <span asp-validation-for="DOBstring"></span>
                    </div>

                    <div class="col-sm-3">
                        <label asp-for="Contact"></label>
                        <input asp-for="Contact" class="form-control" maxlength="11" />
                        <span asp-validation-for="Contact"></span>
                    </div>

                    <div class="col-sm-6">
                        <label asp-for="DesignationId"></label>
                        <select asp-for="DesignationId"
                                asp-items="Model.Designations"
                                class="form-control">
                            <option value="">--Choose--</option>
                        </select>

                        <span asp-validation-for="DesignationId"></span>
                    </div>
                </div>

                <!-- Address / Department -->
                <div class="row mt-2">
                    <div class="col-sm-6">
                        <label asp-for="Address"></label>
                        <textarea asp-for="Address" class="form-control"></textarea>
                        <span asp-validation-for="Address"></span>
                    </div>

                    <div class="col-sm-6">
                        <label asp-for="DepartmentId"></label>
                        <select asp-for="DepartmentId"
                                asp-items="Model.Departments"
                                class="form-control">
                            <option value="">--Choose--</option>
                        </select>

                        <span asp-validation-for="DepartmentId"></span>
                    </div>
                </div>

                <!-- Roles / User Type -->
                <div class="row mt-2">
                    <div class="col-sm-6">
                        <label>Roles</label>
                        <div class="dropdown_main">
                            <span class="dropdown_btn">
                                Roles <i class="fa fa-caret-down"></i>
                            </span>
                            <ul class="dropdown_lists">
                                @if (Model.RolesList != null && Model.RolesList.Any())
                                {
                                    foreach (var item in Model.RolesList)
                                    {
                                        <li>
                                            <label>
                                                <input type="checkbox"
                                                       class="chk-roles-cls"
                                                       value="@item.Value" />
                                                @item.Text
                                            </label>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li>No Roles Found</li>
                                }


                            </ul>
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <label asp-for="UserTypeId"></label>
                        <select asp-for="UserTypeId"
                                asp-items="Model.UserTypes"
                                class="form-control">
                            <option value="">--Choose--</option>
                        </select>

                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                
                <button type="submit" id="btn-addteacher" class="btn pay-now-btn">
                    Save
                </button>
            </div>
        </div>
    </form>
</div>
<script>
    $("#btn-dummy-addteacher").click(function () {

        let roles = [];
        $(".chk-roles-cls:checked").each(function () {
            roles.push($(this).val());
        });

        $("#RoleData").val(roles.join(","));
        $("#form-teacher-add").submit();
    });

    $("#form-teacher-add").submit(function (e) {
        e.preventDefault();

        $.ajax({
            url: $(this).attr("action"),
            type: "POST",
            data: $(this).serialize(),
            success: function (res) {
                AddStaffSuccess(res);
            },
            error: function () {
                ajaxFailure();
            }
        });
    });

    $('#DOBstring').datepicker({
        format: "dd-mm-yyyy",
        autoclose: true,
        todayHighlight: true,
        endDate: new Date()
    });

    $('.dropdown_btn').click(function () {
        $(this).siblings('.dropdown_lists').toggle();
    });
</script>
