@model Satluj_Latest.Models.FeeAlertDataModel

<div class="col-md-12 col-md-offset-1" style="margin-bottom:70%; margin-top:3%;">
    <div class="email-setup-main">

        <form id="form-login"
              asp-controller="School"
              asp-action="EditSMSSenderIdData"
              method="post">

            <div class="form-group">
                <label>School Sender ID</label>

                <input asp-for="SenderDetails.SenderData"
                       class="form-control"
                       style="width:30%;"
                       autocomplete="off"
                       placeholder="Sender ID"
                       id="senderId" />

                <span asp-validation-for="SenderDetails.SenderData" class="text-danger"></span>
            </div>

            <div class="form-group" style="margin-top:15px;">
                <button type="submit" class="btn pay-now-btn">Edit</button>
            </div>

        </form>

    </div>
</div>

<script>
    $("#form-login").submit(function (e) {
        e.preventDefault();

        $.ajax({
            url: $(this).attr("action"),
            type: "POST",
            data: $(this).serialize(),
            success: function (res) {
                AddSchoolSenderIdSuccess(res);
            },
            error: function (err) {
                AddSchoolSenderIdFailed(err);
            }
        });
    });

    $(document).ready(function () {
        $("#senderId").val("");
    });
</script>
