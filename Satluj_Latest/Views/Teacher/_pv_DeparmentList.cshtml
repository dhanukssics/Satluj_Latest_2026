

@model Satluj_Latest.Models.DepartmentsModel
@{
    long schoolId = Model.SchoolId;
    var data = new Satluj_Latest.Data.School(schoolId).GetAllDepartment();
    int x = 1;
        bool IsAdmin = ViewBag.IsAdmin;
}
<table class="table custome-table department-list">
    <thead>
        <tr>
            <th>
                Sl No
            </th>
            <th>
                Department Name
            </th>
            @*<th>
                    Abbreviation
                </th>*@
            @if (IsAdmin == true)
            {
                <th></th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in data)
        {
            <tr>
                <td>@x</td>
                <td>@item.DepartmentName</td>
                @*<td>@item.Abbreviation</td>*@
                @if (IsAdmin == true)
                {
                    <td>
                        <button class="delete-class-tr btn btn-peek" data-deparrtment="@item.Id"><i class="fa fa-trash"></i></button>
                        <button class="edit-class-tr btn btn-peek" data-deparrtment="@item.Id"><i class="fa fa-edit"></i></button>
                    </td>
                }
            </tr>
            x = x + 1;
        }
    </tbody>
</table>
