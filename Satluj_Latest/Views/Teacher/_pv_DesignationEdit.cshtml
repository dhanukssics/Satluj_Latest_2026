@model Satluj_Latest.Models.DesignationModel

<form id="form-teacher-edit"
      asp-action="EditDesignation"
      asp-controller="Teacher"
      method="post">

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Designation :</label>
        <input asp-for="DesignationName"
               class="form-control"
               placeholder="Designation Name" />
        <span asp-validation-for="DesignationName"
              class="text-danger"></span>
    </div>

    <div class="text-right">
        <button type="button"
                class="btn btn-default"
                data-dismiss="modal">
            Cancel
        </button>

        <button type="submit"
                class="btn pay-now-btn">
            Edit
        </button>
    </div>

</form>