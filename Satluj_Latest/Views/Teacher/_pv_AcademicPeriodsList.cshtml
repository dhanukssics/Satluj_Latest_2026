@model Satluj_Latest.Models.AcademicPeriodsModelClass
@{
    long schoolId = Model.SchoolId;
    var data = new Satluj_Latest.Data.School(schoolId).GetAllAcademicPeriods();
    int x = 1;
        bool IsAdmin = ViewBag.IsAdmin;
}
<table class="table custome-table academic-periods-list">
    <thead>
        <tr>
            <th>
                Sl No
            </th>
            <th>
                Class Name
            </th>
            <th>
                Start Date
            </th>
            <th>
                End Date
            </th>
            <th>
                Periods Name
            </th>
            @*@if (IsAdmin == true)
                {
                    <th></th>
                }*@
        </tr>
    </thead>
    <tbody>
        @foreach (var item in data)
        {
            <tr>
                <td>@x</td>
                <td>@item.ClassName</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>@item.PeriodsName</td>
                @*@if (IsAdmin == true)
                    {
                        <td>
                            <button class="delete-class-tr btn btn-peek" data-scho="@item.Id"><i class="fa fa-trash"></i></button>
                            <button class="edit-class-tr btn btn-peek" data-scho="@item.Id"><i class="fa fa-edit"></i></button>
                        </td>
                    }*@
            </tr>
            x = x + 1;
        }
    </tbody>
</table>
