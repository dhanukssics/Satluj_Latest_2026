@model Satluj_Latest.Models.ForgotPasswordModel
@{
    Layout = "_AccountLayout";
}

<section class="login-body">
    <div class="container">
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <div class="login-main">
                    <div class="forgot-pass-mbain">

                        <img src="~/Content/img/logo.png" width="200" class="img-fluid" />

                        <h3 class="main-title">Forgot Password</h3>

                        <p class="custom-warning">
                            Email address you use to log in to your account.
                            We'll send you an email with instructions to choose a new password.
                        </p>

                        <form id="forgotPasswordForm">
                            <div class="form-group">
                                <label>Email</label>
                                <input asp-for="email"
                                       class="form-control"
                                       id="forgotEmail"
                                       placeholder="Enter your E-mail" />
                                <span asp-validation-for="email" class="text-danger"></span>

                                <span id="spn-error-forgotEmail"
                                      class="text-danger"
                                      style="display:none;"></span>
                            </div>

                            <div class="form-group">
                                <button type="submit"
                                        id="btn-ForgotPasswordSend"
                                        class="custom-btn">
                                    Send
                                </button>
                            </div>

                            <div class="form-group">
                                <a asp-controller="Account"
                                   asp-action="SchoolLogin">
                                    Back to login
                                </a>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        // Check email exists
        $('#forgotEmail').on('blur', function () {
            let email = $(this).val();

            $.get('/Account/CheckExistEmail', { text: email }, function (data) {
                if (data.status) {
                    $('#spn-error-forgotEmail').text(data.message).show();
                    $('#btn-ForgotPasswordSend').prop('disabled', true);
                } else {
                    $('#spn-error-forgotEmail').hide();
                    $('#btn-ForgotPasswordSend').prop('disabled', false);
                }
            });
        });

        // Submit form
        $('#forgotPasswordForm').submit(function (e) {
            e.preventDefault();

            $.ajax({
                url: '/Account/SendMailForPassword',
                type: 'POST',
                data: $(this).serialize(),
                success: function (result) {
                    if (result.status) {
                        toastr.success(result.message);
                        setTimeout(() => {
                            window.location.href = '/Account/SchoolLogin';
                        }, 500);
                    } else {
                        toastr.error(result.message);
                    }
                },
                error: function () {
                    toastr.error('Something went wrong');
                }
            });
        });
    </script>
}
