@model Satluj_Latest.Models.LoginModel
@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<style>
    .parent-login-required span {
        float: left;
        color: red;
        padding-top: 5px;
        font-weight: bold;
        font-size: 12px;
    }
</style>

<form id="login-form"
      asp-controller="Account"
      asp-action="CheckLogin"
      method="post"
      style="display:block;">

    <section class="parent_loginFee fullWid">
        <div class="container">
            <div class="row">

                @Html.HiddenFor(m => m.userType, new { @value = 4 })

                <div class="col-md-6">
                    <div class="login">
                        <div class="login-form fullWid">

                            <img class="posiImg" src="~/Content/img/parentPic.png" />

                            <h3>Parent Login</h3>

                            <div class="form-group parent-login-required">
                                @Html.TextBoxFor(m => m.Email, new {
                                @class = "form-control",
                                                                id = "username",
                                                                placeholder = "Username",
                                                                maxlength = 60
                                                                })
                                @Html.ValidationMessageFor(m => m.Email)
                            </div>

                            <div class="form-group parent-login-required">
                                @Html.PasswordFor(m => m.Password, new {
                                                                @class = "form-control",
                                                                id = "password",
                                                                placeholder = "Password",
                                                                maxlength = 60
                                                                })
                                @Html.ValidationMessageFor(m => m.Password)
                            </div>

                            <div class="form-group">
                                <a href="/Account/ForgotPasswordParent" class="forgot-pass">Forgot Password</a>
                                <a href="/Account/ParentRegistration" class="forgot-pass" style="margin-left:100px;">Register Now</a>
                            </div>

                            <div class="form-group">
                                <input type="submit" value="Login" class="submit" />
                            </div>

                        </div>
                    </div>
                </div>

                <div class="col-md-6 logconts">
                    <h2>login for</h2>
                    <p><img src="~/Content/img/attendence.png" /> Attendance Tracking</p>
                    <p><img src="~/Content/img/alerts.png" /> School Alerts</p>
                    <p><img src="~/Content/img/bell.png" /> Notifications</p>
                </div>

            </div>
        </div>
    </section>

</form>

<script>
    $(document).ready(function () {
        $(".se-pre-con").hide();
        $('#userType').val(4);
    });

    $('#login-form').submit(function (e) {
        e.preventDefault();

        $.ajax({
            url: $(this).attr('action'),
            type: 'POST',
            data: $(this).serialize(),
            success: CheckLoginSuccess,
            error: function () {
                alert('Login failed');
            }
        });
    });

    function CheckLoginSuccess(result) {
        if (result.status) {
            $(".se-pre-con").show();

            if (result.userType === 4) {
                $('#errorMsg').hide();
                window.location.href = '/Parent/ParentHome';
            }
        } else {
            toastrError(result.msg);
        }
    }

    $(document).on('keypress', '#password', function (e) {
        if (e.which === 32) return false;
    });
</script>
