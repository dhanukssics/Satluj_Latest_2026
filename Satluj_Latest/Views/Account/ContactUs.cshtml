@model Satluj_Latest.Models.ContactUsModel
@{
    Layout = "~/Views/Shared/_AccountLayout.cshtml";
}

<section class="register-body contact-body">
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <div class="contact-title">
                    <h1 style="padding-top: 1%;">Contact us</h1>
                    <hr />
                </div>
            </div>

            <form id="form-login"
                  method="post"
                  asp-controller="Account"
                  asp-action="Contact">

                <div class="col-md-8">
                    <div class="contact-form">
                        <div class="row">

                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label>Name*</label>
                                    @Html.TextBoxFor(m => m.name, new { @class = "form-control", placeholder = "Your full name" })
                                    @Html.ValidationMessageFor(m => m.name)
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label>Email*</label>
                                    @Html.TextBoxFor(m => m.email, new { @class = "form-control", placeholder = "Your email" })
                                    @Html.ValidationMessageFor(m => m.email)
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label>Contact Number*</label>
                                    @Html.TextBoxFor(m => m.contactNo, new { @class = "form-control", placeholder = "Your contact number" })
                                    @Html.ValidationMessageFor(m => m.contactNo)
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <div class="form-group">
                                    <label>School</label>
                                    @Html.TextBoxFor(m => m.schoolName, new { @class = "form-control", placeholder = "Your school name" })
                                    @Html.ValidationMessageFor(m => m.schoolName)
                                </div>
                            </div>

                            <div class="col-lg-12">
                                <div class="form-group">
                                    <label>Message</label>
                                    @Html.TextAreaFor(m => m.message, new
                                    {
                                        @class = "form-control",
                                                                        placeholder = "Type your message here",
                                                                        rows = 5,
                                                                        style = "resize:vertical;"
                                                                        })
                                    @Html.ValidationMessageFor(m => m.message)
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <div class="form-group">
                                    <input type="submit" value="Submit" class="submit" style="background:#2e3138;" />
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

            </form>

            <div class="col-md-4">
                <div class="reach-us">
                    <h3>Address</h3>
                    <hr />
                    <address>
                        <p><i class="fa fa-map-marker"></i> 1C, 1st Floor, Leela Infopark, Technopark Campus, Trivandrum - 695 581.</p>
                        <p><i class="fa fa-phone"></i> +91 92 49 558800</p>
                        <p><i class="fa fa-envelope-o"></i> childacademy@srishtis.com</p>
                    </address>
                </div>
            </div>

        </div>
    </div>
</section>
<script>
    $("#form-login").submit(function (e) {
        e.preventDefault();

        $.ajax({
            url: '/Account/Contact',
            type: 'POST',
            data: $(this).serialize(),
            success: function (result) {
                ContactUsSuccess(result);
            },
            error: function () {
                ContactUsFailed();
            }
        });
    });

    function ContactUsSuccess(result) {
        if (result.status) {
            $('#form-login')[0].reset();
            toastrSuccess('Thank you for showing interest in us. We will contact you soon.');
        } else {
            toastrError("Something went wrong!");
        }
    }

    function ContactUsFailed() {
        toastrError("Something went wrong!");
    }
</script>
