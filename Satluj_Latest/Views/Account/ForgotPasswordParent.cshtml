@model Satluj_Latest.Models.ForgotPasswordModel

@{
    ViewData["Title"] = "Forgot Password";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/styles.css" />
    <link rel="stylesheet" href="~/Content/Plugins/toastr/toastr.min.css" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="~/Content/Plugins/toastr/toastr.min.js"></script>
    <script src="~/Content/Plugins/toastr/toastrConfig.js"></script>
</head>

<body>
    <div class="container">
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <div class="login-main">
                    <div class="forgot-pass-mbain">

                        <img class="img-fluid" src="/Content/img/logo.png" width="200" />
                        <h3 class="main-title">Forgot Password</h3>

                        <p class="custom-warning">
                            Email address you use to log in to your account.
                            We'll send you an email with instructions to choose a new password.
                        </p>

                        <form id="forgotPasswordMailSend-form">
                            <div class="form-group">
                                <label class="form-title">Email</label>
                                <input asp-for="email"
                                       class="form-control"
                                       id="forgotEmail"
                                       placeholder="Enter your E-mail" />
                                <span asp-validation-for="email" class="text-danger"></span>

                                <span id="spn-error-forgotEmail"
                                      style="color:red; display:none;"></span>
                            </div>

                            <div class="form-group">
                                <button type="submit"
                                        id="btn-ForgotPasswordSend"
                                        class="custom-btn">
                                    Send
                                </button>
                            </div>

                            <div class="form-group">
                                <a href="/Account/ParentLogin">Back to login</a>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Check email existence
        $(document).on('blur', '#forgotEmail', function () {
            let email = $(this).val();
            if (!email) return;

            $.get('/Account/CheckParentExistEmail', { text: email })
                .done(function (data) {
                    if (data.status) {
                        $('#spn-error-forgotEmail').text(data.message).show();
                        $('#btn-ForgotPasswordSend')
                            .prop('disabled', true)
                            .css({ opacity: 0.8 });
                    } else {
                        $('#spn-error-forgotEmail').hide();
                        $('#btn-ForgotPasswordSend')
                            .prop('disabled', false)
                            .css({ opacity: 1 });
                    }
                });
        });

        // Submit forgot password form
        $('#forgotPasswordMailSend-form').on('submit', function (e) {
            e.preventDefault();

            $.ajax({
                url: '@Url.Action("SendMailForPasswordParent", "Account")',
                type: 'POST',
                data: $(this).serialize(),
                success: function (result) {
                    if (result.status) {
                        toastr.success(result.message);
                        setTimeout(function () {
                            window.location.href = "/Account/ParentLogin";
                        }, 500);
                    } else {
                        toastr.error(result.message);
                    }
                },
                error: function () {
                    toastr.error("Something went wrong.");
                }
            });
        });
    </script>
</body>
</html>
