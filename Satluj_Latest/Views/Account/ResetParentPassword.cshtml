@model Satluj_Latest.Models.ChangePasswordModel

@{
    ViewData["Title"] = "Change Password";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/Content/css/bootstrap.css" />
    <link rel="stylesheet" href="~/Content/css/styles.css" />
    <link rel="stylesheet" href="~/Content/Plugins/toastr/toastr.min.css" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="~/Content/Plugins/toastr/toastr.min.js"></script>
    <script src="~/Content/Plugins/toastr/toastrConfig.js"></script>

    <style>
        .error {
            border: 1px solid red;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="row">
            <div class="col-md-6 offset-md-3">
                <div class="login-main">
                    <div class="forgot-pass-mbain">

                        <img class="img-fluid" src="/Content/img/logo.png" width="200" />
                        <h3 class="main-title">Change Your Password</h3>

                        <form id="ResetPasswordWithNew-form">
                            <input asp-for="LoginGuid" type="hidden" />

                            <div class="form-group">
                                <label class="form-title">New Password</label>
                                <input asp-for="password"
                                       class="form-control"
                                       id="newPassword"
                                       type="password"
                                       placeholder="Please Enter the Password" />
                                <span asp-validation-for="password" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-title">Confirm Password</label>
                                <input asp-for="confirmPassword"
                                       class="form-control"
                                       id="newConfirmPassword"
                                       type="password"
                                       placeholder="Please Enter the Password same as above" />
                                <span asp-validation-for="confirmPassword" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <button type="submit"
                                        id="btn-ChangeNewPassword-submit"
                                        class="custom-btn">
                                    Submit
                                </button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Submit form via AJAX
        $('#ResetPasswordWithNew-form').on('submit', function (e) {
            e.preventDefault();

            let valid = true;
            $('#ResetPasswordWithNew-form input[type="password"]').each(function () {
                if (!$(this).val()) {
                    $(this).addClass('error');
                    valid = false;
                } else {
                    $(this).removeClass('error');
                }
            });

            if (!valid) return;

            $.ajax({
                url: '@Url.Action("ChangePasswordWithNewParent", "Account")',
                type: 'POST',
                data: $(this).serialize(),
                success: function (result) {
                    ResetPasswordWithNewSuccess(result);
                },
                error: function () {
                    toastrError("Something went wrong.");
                }
            });
        });

        function ResetPasswordWithNewSuccess(result) {
            if (result.status) {
                toastrSuccess("Successful ...! Please Sign In");
                setTimeout(function () {
                    window.location.href = "/Account/ParentLogin";
                }, 500);
            } else {
                toastrError(result.message);
            }
        }
    </script>
</body>
</html>
